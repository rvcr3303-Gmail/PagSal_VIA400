                   88 PSCL5200-ICE04-N                VALUE '0'.
                   88 PSCL5200-ICE04-S                VALUE '1'.
                15 PSCL5200-NOMEF-CAPLIC   PIC X(02).
                15 PSCL5200-NOMEF-MSG      PIC 9(04).
             10 PSCL5200-OGER              PIC  X(10).
      *         INDICADOR DE ERRO DO CAMPO GERENTE
             10 PSCL5200-OGER-ST.
                15 PSCL5200-ICE05          PIC  X(01).
                   88 PSCL5200-ICE05-N                VALUE '0'.
                   88 PSCL5200-ICE05-S                VALUE '1'.
                15 PSCL5200-OGER-CAPLIC    PIC X(02).
                15 PSCL5200-OGER-MSG       PIC 9(04).
             10 PSCL5200-INDBYP            PIC  X(01).
      *         INDICADOR DE ERRO DO CAMPO INDICADOR BYPASS
             10 PSCL5200-INDBYP-ST.
                15 PSCL5200-ICE06          PIC  X(01).
                   88 PSCL5200-ICE06-N                VALUE '0'.
                   88 PSCL5200-ICE06-S                VALUE '1'.
                15 PSCL5200-INDBYP-CAPLIC    PIC X(02).
                15 PSCL5200-INDBYP-MSG       PIC 9(04).
             10 PSCL5200-CANAL             PIC  X(10).
      *         INDICADOR DE ERRO DO CAMPO CANAL
             10 PSCL5200-CANAL-ST.
                15 PSCL5200-ICE07          PIC  X(01).
                   88 PSCL5200-ICE07-N                VALUE '0'.
                   88 PSCL5200-ICE07-S                VALUE '1'.
                15 PSCL5200-CANAL-CAPLIC   PIC X(02).
                15 PSCL5200-CANAL-MSG      PIC 9(04).
             10 PSCL5200-BIBLI             PIC  X(10).
      *         INDICADOR DE ERRO DO CAMPO BIBLIOTECA
             10 PSCL5200-BIBLI-ST.
                15 PSCL5200-ICE08          PIC  X(01).
                   88 PSCL5200-ICE08-N                VALUE '0'.
                   88 PSCL5200-ICE08-S                VALUE '1'.
                15 PSCL5200-BIBLI-CAPLIC   PIC X(02).
                15 PSCL5200-BIBLI-MSG      PIC 9(04).
             10 PSCL5200-SITR              PIC  X(01).
             10 PSCL5200-USRINT            PIC  X(10).
             10 PSCL5200-AGEN              PIC S9(04) COMP-3.
             10 PSCL5200-DCAR              PIC S9(08) COMP-3.
             10 PSCL5200-DPRO              PIC S9(08) COMP-3.
             10 PSCL5200-NCLIB             PIC S9(09) COMP-3.
             10 PSCL5200-CONTAB            PIC S9(14).
             10 FILLER REDEFINES PSCL5200-CONTAB.
                15 PSCL5200-CONTAB-NCLIB   PIC S9(09).
                15 PSCL5200-CONTAB-NATRB   PIC S9(02).
                15 PSCL5200-CONTAB-NSEQB   PIC S9(03).
             10 PSCL5200-DINTB             PIC S9(08) COMP-3.
             10 PSCL5200-REFORDB           PIC  X(20).
             10 PSCL5200-MONTB             PIC S9(11)V9(2) COMP-3.
             10 PSCL5200-TREGB             PIC S9(14) COMP-3.
             10 PSCL5200-NCLIC             PIC S9(09) COMP-3.
             10 PSCL5200-CONTAC            PIC S9(14).
             10 FILLER REDEFINES PSCL5200-CONTAC.
                15 PSCL5200-CONTAC-NCLIC   PIC S9(09).
                15 PSCL5200-CONTAC-NATRC   PIC S9(02).
                15 PSCL5200-CONTAC-NSEQC   PIC S9(03).
             10 PSCL5200-DINTC             PIC S9(08) COMP-3.
             10 PSCL5200-REFORDC           PIC  X(20).
             10 PSCL5200-MONTC             PIC S9(11)V9(2) COMP-3.
             10 PSCL5200-TREGC             PIC S9(14) COMP-3.
             10 PSCL5200-CODERR            PIC S9(04) COMP-3.
             10 PSCL5200-TREMUN            PIC  X(01).
             10 PSCL5200-TSERV             PIC  X(02).
             10 PSCL5200-FILLER            PIC  X(80).
             10 PSCL5200-IND-FICH-VAZIO    PIC  X(01).
