      PGM /* PARM(&$RCODE) */
      DCL VAR(&$RCODE)  TYPE(*DEC)  LEN( 1 0)
      DCL VAR(&RECORD)  TYPE(*DEC)  LEN(10 0)
      IF ((&$RCODE=0) *OR (&$RCODE=1)) CALL PGM(PSB4167) PARM(&$RCODE)

      ENDPGM
