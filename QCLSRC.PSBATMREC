/*--------------------------------------------------------------*/
/*                                                              */
/*                  SimulaÓÐo de cadeia batch                   */
/*                                                              */
/*--------------------------------------------------------------*/
           PGM
/*--------------------------------------------------------------*/
/* declaraÓÐo de variaveis */
       DCL VAR(&CADEIA)  TYPE(*CHAR) LEN(10) VALUE(PSBATMRECS)
/*--------------------------------------------------------------*/
/* Programas                                                    */
/*--------------------------------------------------------------*/
SUBMIT:    SBMJOB     CMD(CALL PGM(&CADEIA) ) +
                        JOB(VIA_BATCH)                +
                        PRTDEV(*SYSVAL) USER(DSIOPRS) +
                        JOBMSGQFL(*WRAP) INQMSGRPY(*RQD)
/*--------------------------------------------------------------*/
FIM:       ENDPGM
