/*--------------------------------------------------------------*/
/*                                                              */
/*    Cadeia de reorganizańŃo de ficheiros de salarios          */
/*                    (apos expurgo)                            */
/*--------------------------------------------------------------*/
           PGM
/*--------------------------------------------------------------*/
/* declarańŃo de variaveis */
           DCL VAR(&$RCODE)  TYPE(*DEC)  LEN(1 0) VALUE(0)
           DCL VAR(&CADEIA)  TYPE(*CHAR) LEN(10)  VALUE(PSBAT901)
/*--------------------------------------------------------------*/
/* Programas                                                    */
/*--------------------------------------------------------------*/
           DLYJOB     DLY(000010)
           CALL BAB49999 PARM(&$RCODE &CADEIA)
/*--------------------------------------------------------------*/
FIM:       CALL ARB7900 PARM(&CADEIA)
           ENDPGM
