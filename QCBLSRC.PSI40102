           IF VIAL0001-DEBUG-SIM
              MOVE '1000-INICIO-PROGRAMA.' TO VIAL0015-CALLER-ID
              MOVE '12 CAMPOS STATUS     ' TO VIAL0015-CAMPO-NM (1)
              MOVE  PSCV4010-PINCLI-ST     TO VIAL0015-CAMPO-VLR(1)
              MOVE  PSCV4010-PIDINT-ST     TO VIAL0015-CAMPO-VLR(1)(17:)
              MOVE  PSCV4010-PIFORM-ST     TO VIAL0015-CAMPO-VLR(1)(21:)
              MOVE  PSCV4010-PIREFORD-ST   TO VIAL0015-CAMPO-VLR(1)(25:)
              MOVE  PSCV4010-PIMONT-ST     TO VIAL0015-CAMPO-VLR(1)(29:)
              MOVE  PSCV4010-PITREG-ST     TO VIAL0015-CAMPO-VLR(1)(33:)
              MOVE  PSCV4010-PITPROC-ST    TO VIAL0015-CAMPO-VLR(1)(37:)
              MOVE  PSCV4010-PINOMEO-ST    TO VIAL0015-CAMPO-VLR(1)(41:)
              MOVE  PSCV4010-PINOMEF-ST    TO VIAL0015-CAMPO-VLR(1)(45:)
              MOVE '12 CAMPOS STATUS     ' TO VIAL0015-CAMPO-NM (2)
              MOVE  PSCV4010-PIIENVF-ST    TO VIAL0015-CAMPO-VLR(2)
              MOVE  PSCV4010-PICHKSO-ST    TO VIAL0015-CAMPO-VLR(2)(5:)
              MOVE  PSCV4010-PICHKSC-ST    TO VIAL0015-CAMPO-VLR(2)(9:)
              MOVE  PSCV4010-PIBIBLI-ST    TO VIAL0015-CAMPO-VLR(2)(13:)
              MOVE  PSCV4010-PILMSG-ST     TO VIAL0015-CAMPO-VLR(2)(17:)
              MOVE  PSCV4010-PIICONT-ST    TO VIAL0015-CAMPO-VLR(2)(21:)
              MOVE  PSCV4010-PIICANC-ST    TO VIAL0015-CAMPO-VLR(2)(25:)
              MOVE  PSCV4010-PINCLI-B-ST   TO VIAL0015-CAMPO-VLR(2)(29:)
              MOVE  PSCV4010-PIDINT-B-ST   TO VIAL0015-CAMPO-VLR(2)(45:)
              MOVE '12 CAMPOS STATUS     ' TO VIAL0015-CAMPO-NM (3)
