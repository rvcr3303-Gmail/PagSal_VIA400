      *            VARIAVEIS
      *--------------------------------------------------------------
       01  WS-VARIAVEIS.
           05 WS-COD-FORMATO           PIC  X(01).
              88 WS-FORMATO-PS2                    VALUE 'A'.
           05 WS-COMMAND               PIC  X(256) VALUE SPACES.
           05 WS-HEADER-NOCB           PIC  9(09)  VALUE ZEROES.
           05 WS-MONT                  PIC S9(13)V9(2) COMP-3 VALUE 0.
           05 WS-NREG                  PIC S9(14)V     COMP-3 VALUE 0.
           05 WS-DATA-8                PIC  9(08)  COMP       VALUE 0.
           05 WS-DATA-8-B              PIC  9(08)  COMP       VALUE 0.
           05 WS-COUNT                 PIC S9(04)V     COMP-3 VALUE 0.
           05 WS-OGER                  PIC  X(10)  VALUE SPACES.
           05 WS-AGEN                  PIC  9(04)  VALUE ZEROES.

           05 WS-RECORD-ALL.
             10 WS-RECORD              PIC X(150)  VALUE SPACES.
             10 FILLER                 PIC  X(60)  VALUE SPACES.
             10 WS-REC-BEN-DESC-DEB    PIC  X(40)  VALUE SPACES.
             10 WS-REC-BEN-DESC-CRED   PIC  X(40)  VALUE SPACES.
             10 WS-REC-CONTA           PIC  X(21)  VALUE SPACES.

             10 WS-REC-FILLER4         PIC  X(29)  VALUE SPACES.
           05 WS-NOME-CLI              PIC X(040)  VALUE SPACES.
           05 WS-NIB.
              10 WS-NIB-BANCO          PIC  9(04).
              10 WS-NIB-BALCAO         PIC  9(04).
              10 WS-NIB-CONTA          PIC  9(11).
              10 REDEFINES WS-NIB-CONTA.
                 15 WS-NIB-CLIENTE     PIC  9(08).
                 15 WS-NIB-NATUREZA    PIC  9(02).
                 15 WS-NIB-SEQUENCIA   PIC  9(01).
              10 WS-NIB-CHECK-DIGIT    PIC  9(02).
AR0731     05 WS-TIPO-OPERACAO-FICH    PIC  X(02).
              88 WS-TIPO-OPERACAO-FICH-SAL08 VALUE '08'.
              88 WS-TIPO-OPERACAO-FICH-FORN  VALUE '09'.
              88 WS-TIPO-OPERACAO-FICH-SAL69 VALUE '69'.
              88 WS-TIPO-OPERACAO-FICH-SAL80 VALUE '80'.
              88 WS-TIPO-OPERACAO-FICH-SAL   VALUE '08' '69' '80'.
AR0731     05 WS-TIPO-OPERACAO-ECRA    PIC  X(01).
              88 WS-TIPO-OPERACAO-ECRA-SALA  VALUE 'A'.
              88 WS-TIPO-OPERACAO-ECRA-SALB  VALUE 'B'.
              88 WS-TIPO-OPERACAO-ECRA-FORN  VALUE 'C'.
              88 WS-TIPO-OPERACAO-ECRA-SAL   VALUE 'A' 'B'.
           05 WS-COD-OPER                PIC  9(03).
           05 WS-DESCRICAO               PIC  X(40).
           05 WS-CNTA-CCB                PIC  X(13).
           05 WS-IDSP                    PIC  X(01).
           05 WS-SLD-DISP-DO             PIC  S9(19)V99.
           05 WS-SLD-DISP-TOT            PIC  S9(19)V99.
           05 WS-MONTANTE                PIC  S9(19)V99.
           05 WS-MONTANTE-TOTAL          PIC  S9(19)V99.
           05 WS-MONT-CRED-TOT           PIC  S9(19)V99.
           05 WS-VALOR-CREDITOS          PIC  S9(19)V99.
           05 WS-VALOR-CRED-TEI          PIC  S9(19)V99.
           05 WS-VALOR-DESPESAS          PIC  S9(19)V99.
           05 WS-QUANT-CREDITOS          PIC  9(06).
           05 WS-QUANT-CRED-TEI          PIC  9(06).
           05 WS-CCOD                  PIC  X(01)    VALUE SPACES.
           05 WS-CNTA14                PIC  9(14)    VALUE ZEROES.
           05 WS-CNTA14-R REDEFINES WS-CNTA14.
              10 WS-NCLI14             PIC  9(09)    VALUE ZEROES.
              10 WS-NATR14             PIC  9(02)    VALUE ZEROES.
              10 WS-NSEQ14             PIC  9(03)    VALUE ZEROES.
           05 WS-CNTA11                PIC  9(11)    VALUE ZEROES.
           05 WS-CNTA11-R REDEFINES WS-CNTA11.
              10 WS-NCLI               PIC  9(08)    VALUE ZEROES.
              10 WS-NATR               PIC  9(02)    VALUE ZEROES.
              10 WS-NSEQ               PIC  9(01)    VALUE ZEROES.
           05 WS-NIB.
              10 WS-CBAN               PIC  9(04)    VALUE ZEROES.
              10 WS-CBAL               PIC  9(04)    VALUE ZEROES.
              10 WS-CNTA               PIC  9(11)    VALUE ZEROES.
              10 WS-CDIG               PIC  9(02)    VALUE ZEROES.
           05 WS-ERR.
              10 WS-ERR-DESC1          PIC  X(40)    VALUE SPACES.
              10 WS-ERR-DESC2          PIC  X(40)    VALUE SPACES.
              10 WS-ERR-DESC3          PIC  X(40)    VALUE SPACES.
           05 WS-INDICE                PIC  9(03)    VALUE ZEROES.
           05 WS-DINT-98               PIC  9(08)    VALUE ZEROES.
           05 WS-MORADA                PIC  X(40)    VALUE SPACES.
           05 WS-PROVINCIA             PIC  X(30)    VALUE SPACES.
           05 WS-REG-PROCESSADOS       PIC  9(14)    VALUE ZEROES.
           05 WS-MONTANT-PROCESS       PIC S9(13)V99 VALUE ZEROES.
           05 WS-REG-N-PROCESS         PIC  9(14)    VALUE ZEROES.
           05 WS-MONTANT-N-PROCE       PIC S9(13)V99 VALUE ZEROES.
           05 WS-TOTAL-REGISTOS        PIC  9(14)    VALUE ZEROES.
           05 WS-TOTAL-MONTANTE        PIC S9(13)V99 VALUE ZEROES.
           05 WS-TOTAL-COMISSOES       PIC S9(13)V99 VALUE ZEROES.
           05 WS-TOTAL-IMPOSTOS        PIC S9(13)V99 VALUE ZEROES.
           05 WS-TOTAL-DEBITOS         PIC S9(13)V99 VALUE ZEROES.
           05 WS-TOTAL-REG-INTERNOS    PIC S9(08)    VALUE ZEROES.
           05 WS-TOTAL-REG-OIC         PIC S9(08)    VALUE ZEROES.
           05 WS-DIM-SEQMV.
              10 WS-SEQMV OCCURS 100   PIC  9(02).
           05 WS-DIM-PACNT.
              10 WS-PACNT OCCURS 100   PIC  X(03).
           05 WS-DIM-BALC.
              10 WS-BALC  OCCURS 100   PIC  X(04).
