           END-IF.

           MOVE PSCV4010-PIIPAGSAL          TO PSFICHEIR-FCTREMUN.
           MOVE WS-REC-CONTA                TO PSFICHEIR-FCCONTA.

           EXEC SQL
                INSERT INTO PSFICHEIR5
                     ( FCNCLI
                     , FCDINT
                     , FCNFIC
                     , FCNREG
                     , FCNOMEF
                     , FCFORM
                     , FCREG
                     , FCSITU
                     , FCOGER
                     , FCAGEN
                     , FCDCAR
                     , FCDPRO
                     , FCSITR
                     , FCUSRINT
                     , FCUSRCNF
                     , FCINDBYP
                     , FCCANAL
                     , FCNCLIB
                     , FCNATRB
                     , FCNSEQB
                     , FCDINTB
                     , FCREFORDB
                     , FCMONTB
                     , FCTREGB
                     , FCNCLIC
                     , FCNATRC
                     , FCNSEQC
                     , FCDINTC
                     , FCREFORDC
                     , FCMONTC
                     , FCTREGC
                     , CUSERID
                     , HTIMEEST
                     , FCETRBI
                     , FCETRBV
                     , FCTREMUN
                     , FCCONTA
                     , FCCONTAB
                     , FCCONTAC
                     )
                VALUES
                     ( :PSFICHEIR-FCNCLI
                     , :PSFICHEIR-FCDINT
                     , :PSFICHEIR-FCNFIC
                     , :PSFICHEIR-FCNREG
                     , :PSFICHEIR-FCNOMEF
                     , :PSFICHEIR-FCFORM
                     , :PSFICHEIR-FCREG
                     , :PSFICHEIR-FCSITU
                     , :PSFICHEIR-FCOGER
                     , :PSFICHEIR-FCAGEN
                     , :PSFICHEIR-FCDCAR
                     , :PSFICHEIR-FCDPRO
                     , :PSFICHEIR-FCSITR
                     , :PSFICHEIR-FCUSRINT
                     , :PSFICHEIR-FCUSRCNF
                     , :PSFICHEIR-FCINDBYP
                     , :PSFICHEIR-FCCANAL
                     , :PSFICHEIR-FCNCLIB
                     , :PSFICHEIR-FCNATRB
                     , :PSFICHEIR-FCNSEQB
                     , :PSFICHEIR-FCDINTB
                     , :PSFICHEIR-FCREFORDB
                     , :PSFICHEIR-FCMONTB
                     , :PSFICHEIR-FCTREGB
                     , :PSFICHEIR-FCNCLIC
                     , :PSFICHEIR-FCNATRC
                     , :PSFICHEIR-FCNSEQC
                     , :PSFICHEIR-FCDINTC
                     , :PSFICHEIR-FCREFORDC
                     , :PSFICHEIR-FCMONTC
                     , :PSFICHEIR-FCTREGC
                     , :PSFICHEIR-CUSERID
                     ,  CURRENT TIMESTAMP
                     , :PSFICHEIR-FCETRBI
                     , :PSFICHEIR-FCETRBV
                     , :PSFICHEIR-FCTREMUN
                     , :PSFICHEIR-FCCONTA
                     , :PSFICHEIR-FCCONTAB
                     , :PSFICHEIR-FCCONTAC
                     )
           END-EXEC.

           MOVE CON-PSFICHEIR
             TO VIAL0002-TABLE-NAME.

