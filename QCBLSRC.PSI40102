              MOVE '1120-VALIDA-CONTA'     TO VIAL0015-CALLER-ID
              MOVE 'CNTA-MSG'              TO VIAL0015-CAMPO-NM(2)
              MOVE PSCL5040-CNTA-MSG       TO VIAL0015-CAMPO-VLR(2)
              MOVE 'IND-ERROS'             TO VIAL0015-CAMPO-NM(1)
              MOVE VIAL0002-IND-ERROS      TO VIAL0015-CAMPO-VLR(1)
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.

           IF NOT VIAL0002-SEM-ERROS
              SET  PSCV4011-PINCLI-1       TO TRUE
              MOVE PSCK0002-CAPLIC-PS      TO PSCV4011-PINCLI-CAPLIC
              MOVE PSCL5040-CNTA-MSG       TO PSCV4011-PINCLI-MSG
           END-IF.
      *
       1120-VALIDA-CONTA-EXIT.
           EXIT.
      *--------------------------------------------------------------
      *                   1110-OBTEM-NOME-CLI
      *--------------------------------------------------------------
       1110-OBTEM-NOME-CLI.

           IF VIAL0001-DEBUG-SIM
              MOVE '1110-OBTEM-NOME-CLI'   TO VIAL0015-CALLER-ID
              MOVE 'NCLI   '               TO VIAL0015-CAMPO-NM(1)
              MOVE PSCV4010-PINCLI         TO VIAL0015-CAMPO-VLR(1)
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.

           INITIALIZE SXCL0380-DATA.

      *    MOVE ETCL0050-VERSAO            TO SXCL0380-VERSAO
      *    SET  SXCL0380-V203              TO TRUE.
           MOVE VIAL0001-VERSAO-SYS        TO SXCL0380-VERSAO
           MOVE CON-PRG-NAME               TO SXCL0380-PGMC.
           MOVE PSCK0002-TTR-NOME-CLI      TO SXCL0380-TTR.
           MOVE VIAL0001-CALLERID          TO SXCL0380-JOBNC.
           MOVE VIAL0001-CUSER-EXTRN       TO SXCL0380-USERC.
           MOVE VIAL0001-MSGQ              TO SXCL0380-PGMQC.
           MOVE PSCK0002-RCODE-OK          TO SXCL0380-RCODE.
           MOVE PSCK0002-ESTR-NEXE         TO SXCL0380-ESTR.
           MOVE PSCK0002-APTR-APL          TO SXCL0380-APTR.
           MOVE PSCK0002-HCLI-VMSG         TO SXCL0380-HCLI.
           MOVE PSCK0002-VNCR-NVAL         TO SXCL0380-VNCR.
           MOVE ZEROES                     TO SXCL0380-CLBAL.
           MOVE PSCV4010-PINCLI            TO SXCL0380-CLNCLI.

           IF VIAL0001-DEBUG-SIM
              MOVE '1110-OBTEM-NOME-CLI'   TO VIAL0015-CALLER-ID
              MOVE 'NCLI   '               TO VIAL0015-CAMPO-NM(1)
              MOVE PSCV4010-PINCLI         TO VIAL0015-CAMPO-VLR(1)
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.

           CALL SXCL0380-ROTINA         USING SXCL0002-COMMAREA,
                                              SXCL0380-DATA.

           IF VIAL0001-DEBUG-SIM
              MOVE '****-fim sxcl0380  '   TO VIAL0015-CALLER-ID
              MOVE 'NCLI   '               TO VIAL0015-CAMPO-NM(1)
              MOVE PSCV4010-PINCLI         TO VIAL0015-CAMPO-VLR(1)
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.

           MOVE SXCL0380-RCODE             TO VIAW0020-RCODE.

           PERFORM VIAP0020-TRATA-RCODE
              THRU VIAP0020-TRATA-RCODE-EXIT.

           IF NOT VIAL0002-SEM-ERROS
              MOVE PSCK0002-STATUS-ACTIVO   TO PSCV4011-PINCLI-S
              MOVE PSCK0001-COCCLI-N-EXISTS TO PSCV4011-PINCLI-MSG
           ELSE
              MOVE SXCL0380-DWT OF SXCL0380-WT OF SXCL0380-DATA(1)
                                            TO PSCV4011-PINMCLI
                                               WS-NOME-CLI
           END-IF.
      *
       1110-OBTEM-NOME-CLI-EXIT.
           EXIT.

      *--------------------------------------------------------------
      *            2000-PROC-PROGRAMA
      *--------------------------------------------------------------
       2000-PROC-PROGRAMA.

           IF VIAL0001-DEBUG-SIM
              MOVE '2000-PROC-PROGRAMA.'   TO VIAL0015-CALLER-ID
              MOVE 'PSCV4010-ADE       '   TO VIAL0015-CAMPOS-CHAVE
              MOVE  PSCV4010-ADE           TO VIAL0015-CAMPOS-CHAVE
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.

           MOVE PSCV4010-ADE               TO PSCV4011-ADE.

           IF VIAL0002-SEM-ERROS
              PERFORM 2100-OBTEM-DADOS
                 THRU 2199-OBTEM-DADOS-EXIT
           END-IF.

           PERFORM 2900-FORMATA-OUTPUT
              THRU 2999-FORMATA-OUTPUT-EXIT.

       2099-PROC-PROGRAMA-EXIT.
           EXIT.
      *--------------------------------------------------------------
      *                   2100-OBTEM-DADOS
      *--------------------------------------------------------------
       2100-OBTEM-DADOS.

           IF PSCV4010-PIIENVF EQUAL CON-NAO
              PERFORM 2190-FICHEIRO-NAO-RECEB
                 THRU 2190-FICHEIRO-NAO-RECEB-EXIT
           ELSE
              PERFORM 2130-LE-PS2
                 THRU 2139-LE-PS2-EXIT
           END-IF.

       2199-OBTEM-DADOS-EXIT.
           EXIT.

      *--------------------------------------------------------------
      *                   2190-FICHEIRO-NAO-RECEB
      *--------------------------------------------------------------
       2190-FICHEIRO-NAO-RECEB.

           IF VIAL0001-DEBUG-SIM
              MOVE '2190-FICHEIRO-NAO-RECE' TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.

           INITIALIZE RPARAM.
           MOVE PSCK0002-PARAM-INV         TO PSPARAM-PRPARAM.
           PERFORM 2300-PARAM-MSG-ERRO
              THRU 2399-PARAM-MSG-ERRO-EXIT.

           STRING PSCV4011-PILMSG DELIMITED BY '  '
                  PSPARAM-PRPARM0 DELIMITED BY '  '
               '. ' DELIMITED BY '  ' INTO PSCV4011-PILMSG .

           MOVE CON-SIM                    TO PSCV4011-PIICANC.
           MOVE CON-NAO                    TO PSCV4011-PIICONT.

           IF VIAL0001-DEBUG-SIM
              MOVE '2100-OBTEM-DADOS.'     TO VIAL0015-CALLER-ID
              MOVE 'PSCV4010-PIIENVF '     TO VIAL0015-CAMPO-NM(1)
              MOVE  PSCV4010-PIIENVF       TO VIAL0015-CAMPO-VLR(1)

              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.

           PERFORM 2110-OBTEM-NRO-FICHEIRO
              THRU 2119-OBTEM-NRO-FICHEIRO-EXIT.

           IF VIAL0002-SEM-ERROS
              PERFORM 2120-ACTUALIZA-FICHREL
                 THRU 2129-ACTUALIZA-FICHREL-EXIT
           END-IF.

           IF VIAL0002-SEM-ERROS
              MOVE 0                       TO PSCV4011-PINCLI-B
                                              PSCV4011-PICONTA-B
              MOVE SPACES                  TO PSCV4011-PIDINT-B
                                              PSCV4011-PIFORM-B
                                              PSCV4011-PIREFORD-B
              MOVE 0                       TO PSCV4011-PIMONT-B
                                              PSCV4011-PITREG-B
              MOVE 0                       TO PSCV4011-PINCLI-C
                                              PSCV4011-PICONTA-C
              MOVE SPACES                  TO PSCV4011-PIDINT-C
                                              PSCV4011-PIFORM-C
                                              PSCV4011-PIREFORD-C
              MOVE 0                       TO PSCV4011-PIMONT-C
                                              PSCV4011-PITREG-C

              PERFORM 2170-REGISTA-INVALIDO
                 THRU 2179-REGISTA-INVALIDO-EXIT
           END-IF.

       2190-FICHEIRO-NAO-RECEB-EXIT.
           EXIT.

      *--------------------------------------------------------------
      *                   2110-OBTEM-NRO-FICHEIRO
      *--------------------------------------------------------------
       2110-OBTEM-NRO-FICHEIRO.

           IF VIAL0001-DEBUG-SIM
              MOVE '2110-OBTEM-NRO-FICHEI' TO VIAL0015-CALLER-ID
              MOVE 'PSCV4010-PINOMEO     ' TO VIAL0015-CAMPO-NM(1)
              MOVE  PSCV4010-PINOMEO       TO VIAL0015-CAMPO-VLR(1)
              MOVE 'PSCV4010-PINOMEF     ' TO VIAL0015-CAMPO-NM(2)
              MOVE  PSCV4010-PINOMEF       TO VIAL0015-CAMPO-VLR(2)
              MOVE 'PSCV4010-PIIENVF     ' TO VIAL0015-CAMPO-NM(3)
              MOVE  PSCV4010-PIIENVF       TO VIAL0015-CAMPO-VLR(3)
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.

           MOVE PSCV4010-PINCLI         TO PSFICHREL-FRNCLI.

      * CONVERTE DATA DE X(10) PARA 9(08)
           MOVE PSCV4010-PIDINT         TO AQCW0005-DTX10.
           PERFORM AQCP0005-CONV-DT10INDT8
              THRU AQCP0005-CONV-DT10INDT8-EXIT          .
           MOVE AQCW0005-DT98           TO WS-DATA-8     .
           MOVE WS-DATA-8               TO PSFICHREL-FRDINT.

           EXEC SQL
               SELECT IFNULL(MAX(FRNFIC), 0)
                 INTO :PSFICHREL-FRNFIC
                 FROM PSFICHREL
                WHERE FRNCLI = :PSFICHREL-FRNCLI
                  AND FRDINT = :PSFICHREL-FRDINT
           END-EXEC.

           MOVE CON-PSFICHREL
             TO VIAL0002-TABLE-NAME.

           PERFORM 9020-DB2CHECK
              THRU 9029-DB2CHECK-EXIT.

           IF VIAL0002-SEM-ERROS
              IF DB2-OK
                 ADD CON-1                  TO PSFICHREL-FRNFIC
              ELSE
                 MOVE VIAK0002-ERROS-FUNCAO
                   TO VIAL0002-IND-ERROS
                 MOVE PSCK0002-STATUS-ACTIVO
                   TO PSCV4011-PINCLI-C-S
                 MOVE PSCK0001-PINCLI-C-N-EXISTS
                   TO PSCV4011-PINCLI-C-MSG
                 MOVE PSCK0002-STATUS-ACTIVO
                   TO PSCV4011-PIDINT-C-S
                 MOVE PSCK0001-PIDINT-C-N-EXISTS
                   TO PSCV4011-PIDINT-C-MSG
              END-IF
           ELSE
              MOVE VIAK0002-ERROS-FUNCAO
                TO VIAL0002-IND-ERROS
              MOVE PSCK0002-STATUS-ACTIVO
                TO PSCV4011-PINCLI-C-S
              MOVE PSCK0001-PINCLI-C-N-EXISTS
                TO PSCV4011-PINCLI-C-MSG
              MOVE PSCK0002-STATUS-ACTIVO
                TO PSCV4011-PIDINT-C-S
              MOVE PSCK0001-PIDINT-C-N-EXISTS
                TO PSCV4011-PIDINT-C-MSG
           END-IF.

       2119-OBTEM-NRO-FICHEIRO-EXIT.
           EXIT.

      *--------------------------------------------------------------
      *                   2120-ACTUALIZA-FICHREL
      *--------------------------------------------------------------
       2120-ACTUALIZA-FICHREL.

           IF VIAL0001-DEBUG-SIM
              MOVE '2120-ACTUALIZA-FICHRE' TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.

           MOVE PSCV4010-PINCLI             TO PSFICHREL-FRNCLI
      * CONVERTE DATA DE X(10) PARA 9(08)
           MOVE PSCV4010-PIDINT             TO AQCW0005-DTX10
           PERFORM AQCP0005-CONV-DT10INDT8
              THRU AQCP0005-CONV-DT10INDT8-EXIT
           MOVE AQCW0005-DT98               TO WS-DATA-8
           MOVE WS-DATA-8                   TO PSFICHREL-FRDINT
           MOVE PSCV4010-PIFORM             TO PSFICHREL-FRFORM
           MOVE PSCV4010-PINOMEO            TO PSFICHREL-FRNOMEO
           MOVE PSCV4010-PINOMEF            TO PSFICHREL-FRNOMEF
           MOVE ZEROES                      TO PSFICHREL-FRCHKSO
                                               PSFICHREL-FRCHKSC
           MOVE PSCV4010-PIBIBLI            TO PSFICHREL-FRBIBLI
           MOVE VIAL0001-CUSER-EXTRN        TO PSFICHREL-CUSERID


           EXEC SQL
               INSERT INTO PSFICHREL
                    ( FRNCLI,  FRDINT,  FRNFIC,  FRFORM
                    , FRNOMEO, FRNOMEF, FRCHKSO, FRCHKSC
                    , FRBIBLI, CUSERID, HTIMEEST)
             VALUES ( :PSFICHREL-FRNCLI
                    , :PSFICHREL-FRDINT
                    , :PSFICHREL-FRNFIC
                    , :PSFICHREL-FRFORM
                    , :PSFICHREL-FRNOMEO
                    , :PSFICHREL-FRNOMEF
                    , :PSFICHREL-FRCHKSO
                    , :PSFICHREL-FRCHKSC
                    , :PSFICHREL-FRBIBLI
                    , :PSFICHREL-CUSERID
                    , CURRENT TIMESTAMP)
           END-EXEC.

           MOVE CON-PSFICHREL              TO VIAL0002-TABLE-NAME.


           PERFORM 9020-DB2CHECK
              THRU 9029-DB2CHECK-EXIT.

           IF NOT VIAL0002-SEM-ERROS
              MOVE VIAK0002-ERROS-FUNCAO   TO VIAL0002-IND-ERROS
              MOVE PSCK0002-STATUS-ACTIVO  TO PSCV4011-PINCLI-S
              MOVE PSCK0001-PINCLI-N-EXISTS
                                           TO PSCV4011-PINCLI-MSG
              MOVE PSCK0002-STATUS-ACTIVO  TO PSCV4011-PIDINT-S
              MOVE PSCK0001-PIDINT-N-EXISTS
                                           TO PSCV4011-PIDINT-MSG
           ELSE
              MOVE PSFICHREL-FRNFIC        TO PSCV4011-PINFIC
      * SEMPRE QUE O FICHEIRO FOI RECEPCIONADO TEM DE SE
      * GARANTIR A CRIACAO DO REGISTO DA SUA RECEPCAO
              EXEC SQL
                  COMMIT
              END-EXEC

              PERFORM 9020-DB2CHECK
                 THRU 9029-DB2CHECK-EXIT

              IF NOT VIAL0002-SEM-ERROS
                 MOVE VIAK0002-ERROS-FUNCAO
                   TO VIAL0002-IND-ERROS
                 MOVE PSCK0002-STATUS-ACTIVO
                   TO PSCV4011-PINCLI-S
                 MOVE PSCK0001-PINCLI-N-EXISTS
                   TO PSCV4011-PINCLI-MSG
                 MOVE PSCK0002-STATUS-ACTIVO
                   TO PSCV4011-PIDINT-S
                 MOVE PSCK0001-PIDINT-N-EXISTS
                   TO PSCV4011-PIDINT-MSG
              END-IF
           END-IF.

       2129-ACTUALIZA-FICHREL-EXIT.
           EXIT.

      *--------------------------------------------------------------
      *            2130-LE-PS2
      *--------------------------------------------------------------
       2130-LE-PS2.

           IF VIAL0001-DEBUG-SIM
              MOVE '2130-LE-PS2.'       TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.

           PERFORM 2140-VERIFICA-NOMEF
              THRU 2149-VERIFICA-NOMEF-EXIT.

           IF VIAL0002-SEM-ERROS
              IF WS-COUNT EQUAL ZERO
                 PERFORM 2110-OBTEM-NRO-FICHEIRO
                    THRU 2119-OBTEM-NRO-FICHEIRO-EXIT
              END-IF
           END-IF.

           IF VIAL0002-SEM-ERROS
              IF WS-COUNT EQUAL ZERO
                 PERFORM 2120-ACTUALIZA-FICHREL
                    THRU 2129-ACTUALIZA-FICHREL-EXIT
              END-IF
           END-IF.

           MOVE VIAL0001-CUSER-EXTRN TO WS-OGER

           IF VIAL0002-SEM-ERROS
              PERFORM 2150-VALIDA-FICHEIRO
                 THRU 2159-VALIDA-FICHEIRO-EXIT
           END-IF.

           IF VIAL0002-SEM-ERROS
              PERFORM 2155-TRATA-MENSAGEM
                 THRU 2155-TRATA-MENSAGEM-EXIT
           END-IF.

           IF VIAL0001-DEBUG-SIM
              MOVE 'VIAL0002-SEM-ERROS  '  TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.

           IF VIAL0002-SEM-ERROS
              PERFORM 2160-OUTRAS-VALIDACOES
                 THRU 2169-OUTRAS-VALIDACOES-EXIT
           END-IF.

       2139-LE-PS2-EXIT.
           EXIT.

      *--------------------------------------------------------------
      *                   2140-VERIFICA-NOMEF
      *--------------------------------------------------------------
       2140-VERIFICA-NOMEF.

           IF VIAL0001-DEBUG-SIM
              MOVE '2140-VERIFICA-NOMEF'   TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.

           MOVE ZERO                        TO WS-COUNT.

           MOVE PSCV4010-PINOMEF
             TO PSFICHREL-FRNOMEF

           EXEC SQL
               SELECT COUNT(*)
                 INTO :WS-COUNT
                 FROM PSFICHREL
                WHERE FRNOMEF = :PSFICHREL-FRNOMEF
           END-EXEC.

           MOVE CON-PSFICHREL
             TO VIAL0002-TABLE-NAME.

           PERFORM 9020-DB2CHECK
              THRU 9029-DB2CHECK-EXIT.

           IF VIAL0002-SEM-ERROS
              IF WS-COUNT GREATER ZERO
                 PERFORM 2110-OBTEM-NRO-FICHEIRO
                    THRU 2119-OBTEM-NRO-FICHEIRO-EXIT
                 SUBTRACT CON-1 FROM PSFICHREL-FRNFIC
              END-IF
           ELSE
              MOVE VIAK0002-ERROS-FUNCAO
                TO VIAL0002-IND-ERROS
              MOVE PSCK0002-STATUS-ACTIVO
                TO PSCV4011-PINCLI-S
              MOVE PSCK0001-PINCLI-N-EXISTS
                TO PSCV4011-PINCLI-MSG
              MOVE PSCK0002-STATUS-ACTIVO
                TO PSCV4011-PIDINT-S
              MOVE PSCK0001-PIDINT-N-EXISTS
                TO PSCV4011-PIDINT-MSG
           END-IF.

       2149-VERIFICA-NOMEF-EXIT.
           EXIT.

      *--------------------------------------------------------------
      *            2150-VALIDA-FICHEIRO
      *--------------------------------------------------------------
       2150-VALIDA-FICHEIRO.

           IF VIAL0001-DEBUG-SIM
              MOVE '2150-VALIDA-FICHEIRO'  TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.

           INITIALIZE                         PSCL5230-DATA.
           MOVE PSCV4010-PINCLI            TO PSCL5230-NCLI.

      * CONVERTE DATA DE X(10) PARA 9(08)
           MOVE PSCV4010-PIDINT            TO AQCW0005-DTX10.
           PERFORM AQCP0005-CONV-DT10INDT8
              THRU AQCP0005-CONV-DT10INDT8-EXIT.
           MOVE AQCW0005-DT98              TO WS-DATA-8.

           MOVE WS-DATA-8                  TO PSCL5230-DINT.
           MOVE PSFICHREL-FRNFIC           TO PSCL5230-NFIC  .
           MOVE PSCV4010-PINOMEF           TO PSCL5230-NOMEF .
           MOVE PSCV4010-PIBIBLI           TO PSCL5230-BIBLI .
           MOVE WS-OGER                    TO PSCL5230-OGER  .
           MOVE PSCK0002-SEM-BYPASS        TO PSCL5230-INDBYP.
           MOVE VIAL0001-ORIGEM            TO PSCL5230-CANAL.
           MOVE CON-PRG-NAME               TO PSCL5230-PGMC .
           MOVE PSCK0002-TTR-PS2           TO PSCL5230-TTR  .
           MOVE VIAL0001-CALLERID          TO PSCL5230-JOBNC.
           MOVE VIAL0001-CUSER-EXTRN       TO PSCL5230-USERC.
           MOVE VIAL0001-MSGQ              TO PSCL5230-PGMQC.
           MOVE PSCK0002-RCODE-OK          TO PSCL5230-RCODE.
           MOVE PSCK0002-ESTR-NEXE         TO PSCL5230-ESTR.
           MOVE PSCK0002-APTR-APL          TO PSCL5230-APTR.
           MOVE ZEROES                     TO PSCL5230-CODERR.
           MOVE VIAL0001-CBANCO            TO PSCL5230-AT-CBAN
           MOVE VIAL0001-CBALM             TO PSCL5230-AT-BALM
           MOVE VIAL0001-DATA-EXTRN        TO PSCL5230-AT-DTOP
           MOVE VIAL0001-CMOEDA            TO PSCL5230-AT-CMOE
           MOVE VIAL0001-I-DEBUG           TO PSCL5230-AT-DEBUG

           CALL CON-PSM5230 USING ETCL0002-COMMAREA PSCL5230-DATA.

           MOVE PSCL5230-RCODE             TO VIAW0020-RCODE.

           PERFORM VIAP0020-TRATA-RCODE
              THRU VIAP0020-TRATA-RCODE-EXIT.

           IF NOT VIAL0002-SEM-ERROS
d--b          MOVE PSCK0002-STATUS-ACTIVO   TO PSCV4011-PINCLI-S
d--b          MOVE PSCK0001-PINCLI-N-EXISTS TO PSCV4011-PINCLI-MSG
d--b          MOVE PSCK0002-STATUS-ACTIVO   TO PSCV4011-PIDINT-S
d--b          MOVE PSCK0001-PIDINT-N-EXISTS TO PSCV4011-PIDINT-MSG
           ELSE
              IF PSCL5230-INDINV EQUAL CON-YES
                 MOVE PSCK0002-CAPLIC-PS     TO PSCV4011-PIFORM-CAPLIC
                 MOVE PSCK0002-STATUS-ACTIVO TO PSCV4011-PIFORM-S
                 MOVE PSCL5230-CODERR        TO PSCV4011-PIFORM-MSG
              END-IF
              IF VIAL0001-DEBUG-SIM
                 MOVE '**** INDIV          '  TO VIAL0015-CALLER-ID
                 MOVE 'PSCL5230-INDINV'       TO VIAL0015-CAMPO-NM(1)
                 MOVE PSCL5230-INDINV         TO VIAL0015-CAMPO-VLR(1)
                 MOVE 'PSCL5230-INDDUP'       TO VIAL0015-CAMPO-NM(2)
                 MOVE PSCL5230-INDDUP         TO VIAL0015-CAMPO-VLR(2)
                 PERFORM VIAP0016-TRATA-DEBUG
                    THRU VIAP0016-TRATA-DEBUG-EXIT
              END-IF
           END-IF.

       2159-VALIDA-FICHEIRO-EXIT.
           EXIT.

      *--------------------------------------------------------------
      *            2155-TRATA-MENSAGEM
      *--------------------------------------------------------------
       2155-TRATA-MENSAGEM.

           IF VIAL0001-DEBUG-SIM
              MOVE '2155-TRATA-MENSAGEM'   TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.

           IF PSCL5230-INDINV EQUAL CON-YES
              MOVE CON-SIM                 TO PSCV4011-PIICANC
              MOVE CON-NAO                 TO PSCV4011-PIICONT

              INITIALIZE RPARAM
              MOVE PSCK0002-PARAM-INV      TO PSPARAM-PRPARAM
              PERFORM 2300-PARAM-MSG-ERRO
                 THRU 2399-PARAM-MSG-ERRO-EXIT

              STRING PSCV4011-PILMSG DELIMITED BY '  '
                     PSPARAM-PRPARM0 DELIMITED BY '  '
               '. ' DELIMITED BY '  '    INTO PSCV4011-PILMSG
              MOVE 0                       TO PSCV4011-PINCLI-B
                                              PSCV4011-PICONTA-B
              MOVE SPACES                  TO PSCV4011-PIDINT-B
                                              PSCV4011-PIFORM-B
                                              PSCV4011-PIREFORD-B
              MOVE 0                       TO PSCV4011-PIMONT-B
                                              PSCV4011-PITREG-B
           ELSE
              IF PSCL5230-INDDUP EQUAL CON-YES
                 MOVE CON-SIM              TO PSCV4011-PIICANC
                 MOVE CON-SIM              TO PSCV4011-PIICONT

                 INITIALIZE RPARAM
                 MOVE PSCK0002-PARAM-DUP   TO PSPARAM-PRPARAM
                 PERFORM 2300-PARAM-MSG-ERRO
                    THRU 2399-PARAM-MSG-ERRO-EXIT

                 STRING PSCV4011-PILMSG DELIMITED BY '  '
                        PSPARAM-PRPARM0 DELIMITED BY '  '
               '. ' DELIMITED BY '  ' INTO PSCV4011-PILMSG
              ELSE
                 MOVE CON-SIM TO PSCV4011-PIICANC
                 MOVE CON-SIM TO PSCV4011-PIICONT
              END-IF
           END-IF.

           IF VIAL0001-DEBUG-SIM
              MOVE '2155-TRATA-MENSAGE-FIM' TO VIAL0015-CALLER-ID
              MOVE 'RCODE'                  TO VIAL0015-CAMPO-NM(1)
              MOVE 'DUPLICADO'              TO VIAL0015-CAMPO-NM(2)
              MOVE PSCL5230-INDDUP          TO VIAL0015-CAMPO-VLR(2)
              MOVE 'INVALIDO'               TO VIAL0015-CAMPO-NM(3)
              MOVE PSCL5230-INDINV          TO VIAL0015-CAMPO-VLR(3)
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.

       2155-TRATA-MENSAGEM-EXIT.
           EXIT.

      *--------------------------------------------------------------
      *            2160-OUTRAS-VALIDACOES
      *--------------------------------------------------------------
       2160-OUTRAS-VALIDACOES.

           IF VIAL0001-DEBUG-SIM
              MOVE '2160-OUTRAS-VALIDACOE' TO VIAL0015-CALLER-ID
              MOVE 'PSCV4010-PIBIBLI '     TO VIAL0015-CAMPO-NM(1)
              MOVE PSCV4010-PIBIBLI        TO VIAL0015-CAMPO-VLR(1)
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.

           MOVE ZERO                       TO WS-MONT.
           MOVE ZERO                       TO WS-NREG.

           MOVE SPACES                     TO WS-COMMAND.
           STRING 'OVRDBF ' CON-PSFICHPS2 DELIMITED BY SIZE
              ' ' PSCV4010-PIBIBLI DELIMITED BY SPACES
              '/' PSCV4010-PINOMEF DELIMITED BY SPACES
                                         INTO WS-COMMAND.

           IF VIAL0001-DEBUG-SIM
              MOVE 'COPIA DO FICHEIRO'  TO VIAL0015-CALLER-ID
              MOVE 'COMANDO'            TO VIAL0015-CAMPO-NM(1)
              MOVE WS-COMMAND           TO VIAL0015-CAMPO-VLR(1)
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.

           CALL CON-QCMDEXC USING WS-COMMAND, CON-LENGTH.

           OPEN INPUT PSFICHPS2.

           IF VIAL0001-DEBUG-SIM
              MOVE 'Abre Ficheiro'      TO VIAL0015-CALLER-ID
              MOVE 'OPEN'               TO VIAL0015-CAMPO-NM(1)
              MOVE WS-PSFICHPS2-STATUS  TO VIAL0015-CAMPO-VLR(1)
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.

           IF NOT WS-PSFICHPS2-OK
              SET VIAL0002-ERROS-FUNCAO     TO TRUE
           ELSE
              READ PSFICHPS2

              IF VIAL0001-DEBUG-SIM
                 MOVE 'Lę ficheiro 2160'    TO VIAL0015-CALLER-ID
                 MOVE 'READ'                TO VIAL0015-CAMPO-NM(1)
                 MOVE WS-PSFICHPS2-STATUS   TO VIAL0015-CAMPO-VLR(1)
      **R 2026-02-09
                 MOVE 'PSCWPS2-TIPO-REGISTO' TO VIAL0015-CAMPO-NM(2)
                 MOVE PSCWPS2-TIPO-REGISTO   TO VIAL0015-CAMPO-VLR(2)
                 MOVE 'PSCWPS2-FILLER2'      TO VIAL0015-CAMPO-NM(3)
                 MOVE PSCWPS2-FILLER2        TO VIAL0015-CAMPO-VLR(3)
                 MOVE 'PSCWPS2-ORD-CTA-ORIG' TO VIAL0015-CAMPO-NM(4)
                 MOVE PSCWPS2-ORD-CTA-ORIG   TO VIAL0015-CAMPO-VLR(4)
      **R 2026-02-09
                 PERFORM VIAP0016-TRATA-DEBUG
                    THRU VIAP0016-TRATA-DEBUG-EXIT
              END-IF

              IF NOT WS-PSFICHPS2-OK
                 SET VIAL0002-ERROS-FUNCAO     TO TRUE
              END-IF

              IF VIAL0002-SEM-ERROS
                 IF PSCL5230-INDINV EQUAL CON-YES
                    PERFORM 2170-REGISTA-INVALIDO
                       THRU 2179-REGISTA-INVALIDO-EXIT
                 END-IF
              END-IF
           END-IF.

           IF NOT VIAL0002-SEM-ERROS
              MOVE PSCK0002-STATUS-ACTIVO
                TO PSCV4011-PICONTA-S
              MOVE PSCK0001-ERR-UPLOAD-PS2
                TO PSCV4011-PICONTA-MSG
           END-IF.
AR0731*
AR0731*    IF PSCL5230-INDINV EQUAL CON-NAO
AR0731*       PERFORM 2210-VAL-TIPO-PAGAMENTO
AR0731*          THRU 2210-VAL-TIPO-PAGAMENTO-EXIT
AR0731*    END-IF.
AR0731*
           IF PSCL5230-INDINV EQUAL CON-NAO
              PERFORM 2180-PROCESSA-PS2
                 THRU 2189-PROCESSA-PS2-EXIT
                UNTIL NOT VIAL0002-SEM-ERROS
                   OR NOT WS-PSFICHPS2-OK
           END-IF.

           CLOSE PSFICHPS2.

           IF NOT WS-PSFICHPS2-OK AND
              NOT WS-PSFICHPS2-EOF
              SET VIAL0002-ERROS-FUNCAO    TO TRUE
              IF VIAL0001-DEBUG-SIM
                 MOVE 'CLOSE DO FICHEIRO ' TO VIAL0015-CALLER-ID
                 MOVE 'RECORD'             TO VIAL0015-CAMPO-NM(1)
                 MOVE PSFICHPS2-RECORD     TO VIAL0015-CAMPO-VLR(1)
                 MOVE 'STATUS'             TO VIAL0015-CAMPO-NM(2)
                 MOVE WS-PSFICHPS2-STATUS  TO VIAL0015-CAMPO-VLR(2)
                 PERFORM VIAP0016-TRATA-DEBUG
                    THRU VIAP0016-TRATA-DEBUG-EXIT
              END-IF
           END-IF.

       2169-OUTRAS-VALIDACOES-EXIT.
           EXIT.

      *--------------------------------------------------------------
      *            2200-VALIDA-TIPO-PAG
      *--------------------------------------------------------------
       2200-VALIDA-TIPO-PAG.
      *
           IF VIAL0001-DEBUG-SIM
              MOVE '2200-VALIDA-TIPO-PAGAMENTO' TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.

           MOVE ZERO                       TO WS-MONT.
           MOVE ZERO                       TO WS-NREG.

           MOVE SPACES                     TO WS-COMMAND.
           STRING 'OVRDBF ' CON-PSFICHPS2 DELIMITED BY SIZE
              ' ' PSCV4010-PIBIBLI DELIMITED BY SPACES
              '/' PSCV4010-PINOMEF DELIMITED BY SPACES
                                         INTO WS-COMMAND.

           CALL CON-QCMDEXC USING WS-COMMAND, CON-LENGTH.

           OPEN INPUT PSFICHPS2.

           IF NOT WS-PSFICHPS2-OK
              SET VIAL0002-ERROS-FUNCAO     TO TRUE
           ELSE
              READ PSFICHPS2

              IF VIAL0001-DEBUG-SIM
                 MOVE 'Lę ficheiro 2200'    TO VIAL0015-CALLER-ID
                 MOVE 'READ'                TO VIAL0015-CAMPO-NM(1)
                 MOVE WS-PSFICHPS2-STATUS   TO VIAL0015-CAMPO-VLR(1)
      **R 2026-02-09
                 MOVE 'PSCWPS2-TIPO-REGISTO' TO VIAL0015-CAMPO-NM(2)
                 MOVE PSCWPS2-TIPO-REGISTO   TO VIAL0015-CAMPO-VLR(2)
                 MOVE 'PSCWPS2-FILLER2'      TO VIAL0015-CAMPO-NM(3)
                 MOVE PSCWPS2-FILLER2        TO VIAL0015-CAMPO-VLR(3)
                 MOVE 'PSCWPS2-ORD-CTA-ORIG' TO VIAL0015-CAMPO-NM(4)
                 MOVE PSCWPS2-ORD-CTA-ORIG   TO VIAL0015-CAMPO-VLR(4)
                 MOVE 'PSCWPS2-CONTA       ' TO VIAL0015-CAMPO-NM(5)
                 MOVE PSCWPS2-CONTA          TO VIAL0015-CAMPO-VLR(5)
                 MOVE 'PSCWPS2-FILLER4     ' TO VIAL0015-CAMPO-NM(6)
                 MOVE PSCWPS2-FILLER4        TO VIAL0015-CAMPO-VLR(6)
      **R 2026-02-09
                 PERFORM VIAP0016-TRATA-DEBUG
                    THRU VIAP0016-TRATA-DEBUG-EXIT
              END-IF

              IF NOT WS-PSFICHPS2-OK
                 SET VIAL0002-ERROS-FUNCAO TO TRUE
AR0812           MOVE PSCK0002-STATUS-ACTIVO
                                           TO PSCV4011-PIFORM-S
                 MOVE PSCK0001-ERR-FORM    TO PSCV4011-PIFORM-MSG
                 MOVE PSCK0002-CAPLIC-PS   TO PSCV4011-PIFORM-CAPLIC
              ELSE
                 PERFORM 2210-VAL-TIPO-PAGAMENTO
                    THRU 2210-VAL-TIPO-PAGAMENTO-EXIT
              END-IF
           END-IF

           CLOSE PSFICHPS2.

           IF NOT WS-PSFICHPS2-OK AND
              NOT WS-PSFICHPS2-EOF
              SET VIAL0002-ERROS-FUNCAO    TO TRUE
              IF VIAL0001-DEBUG-SIM
                 MOVE 'CLOSE DO FICHEIRO ' TO VIAL0015-CALLER-ID
                 MOVE 'RECORD'             TO VIAL0015-CAMPO-NM(1)
                 MOVE PSFICHPS2-RECORD     TO VIAL0015-CAMPO-VLR(1)
                 MOVE 'STATUS'             TO VIAL0015-CAMPO-NM(2)
                 MOVE WS-PSFICHPS2-STATUS  TO VIAL0015-CAMPO-VLR(2)
                 PERFORM VIAP0016-TRATA-DEBUG
                    THRU VIAP0016-TRATA-DEBUG-EXIT
