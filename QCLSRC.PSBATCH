/*--------------------------------------------------------------*/
/*                                                              */
/*                  SimulaÓÐo de cadeia batch                   */
/*                                                              */
/*--------------------------------------------------------------*/
           PGM
/*--------------------------------------------------------------*/
/* declaraÓÐo de variaveis */
           DCL VAR(&SUBMIT)  TYPE(*CHAR) LEN(10)  VALUE(*SBMT)
/*--------------------------------------------------------------*/
/*--------------------------------------------------------------*/
/* Programas                                                    */
/*--------------------------------------------------------------*/
SUBMIT:    SBMJOB     CMD(CALL PGM(PSBATCHS) )           +
                        JOB(VIA_BATCH) JOBQ(BCI/VIAJOBS) +
                        PRTDEV(*SYSVAL) USER(DSIOPRS)    +
                        JOBMSGQFL(*WRAP) INQMSGRPY(*RQD)

/*--------------------------------------------------------------*/
FIM:       ENDPGM
