                 88 ETCL9127-RCODE-OK              VALUE 0.
                 88 ETCL9127-RCODE-INF             VALUE 1.
                 88 ETCL9127-RCODE-VAL             VALUE 2.
                 88 ETCL9127-RCODE-APL             VALUE 3.
                 88 ETCL9127-RCODE-ERR             VALUE 2 3.
              10 ETCL9127-ESTR          PIC  X(01).
                 88 ETCL9127-ESTR-NEXE             VALUE '0'.
                 88 ETCL9127-ESTR-EXE              VALUE '1'.
              10 ETCL9127-APTR          PIC  X(01).
                 88 ETCL9127-APTR-APL              VALUE 'A'.
                 88 ETCL9127-APTR-VAL              VALUE 'V'.
              10 ETCL9127-EXCT          PIC  X(01).
                 88 ETCL9127-EXCT-COMPEN           VALUE 'C'.
                 88 ETCL9127-EXCT-FRONTO           VALUE 'F'.
                 88 ETCL9127-EXCT-TRANSF           VALUE 'T'.
              10 ETCL9127-HCLI          PIC  X(01).
