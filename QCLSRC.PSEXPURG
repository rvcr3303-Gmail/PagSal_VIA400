/*--------------------------------------------------------------*/
/*                                                              */
/*       Cadeia Batch de Expurgos (Pag. Sal·rios) - Submit      */
/*                                                              */
/*--------------------------------------------------------------*/
           PGM

/*--------------------------------------------------------------*/
/* Declara vari·veis                                            */
/*--------------------------------------------------------------*/
       DCL VAR(&CADEIA)  TYPE(*CHAR) LEN(10) VALUE(PSEXPURGS)

/*--------------------------------------------------------------*/
/* Programas                                                    */
/*--------------------------------------------------------------*/
SUBMIT:
       SBMJOB     CMD(CALL PGM(&CADEIA) )          +
                  JOB(VIA_BATCH)                   +
                  PRTDEV(*SYSVAL)  USER(DSIOPRS)   +
                  JOBMSGQFL(*WRAP) INQMSGRPY(*RQD)

/*--------------------------------------------------------------*/
/* Fim                                                          */
/*--------------------------------------------------------------*/
FIM:
       ENDPGM
