      *--------------------------------------------------------------
       COPY VIAL0015.
       COPY VIAW0005.
       COPY VIAK0001.
       COPY VIAK0002.
       COPY PSCK0001.
       COPY PSCK0002.
       COPY VIAW0020.
       COPY AQCW0005.
       COPY AQCW0100.
       COPY SXCL0610.
       COPY SXCL0002.
       COPY SXCL0380.
       COPY ETCL0002.
       COPY ARCK0001.
       COPY ARCK0002.
       COPY PSCW5035.
       COPY PSCW5070.
       COPY PSCL5700.
       COPY PSCL5035.
       COPY PSCL5070.
       COPY ARCL5005.
       COPY PSCL5250.
       COPY ETCL9076.
       COPY ETCL0188.
      *--------------------------------------------------------------
      *            AREAS DE TRABALHO
      *--------------------------------------------------------------
      *--------------------------------------------------------------
      *            SWITCH
      *--------------------------------------------------------------
       01  SW-SWITCH.
           05 SW-CURSOR                  PIC X(01) VALUE SPACES.
              88 SW-CURSOR-NONE                    VALUE '0'.
              88 SW-CURSOR-1                       VALUE '1'.
              88 SW-CURSOR-2                       VALUE '2'.
              88 SW-CURSOR-3                       VALUE '3'.
              88 SW-CURSOR-4                       VALUE '3'.
AR0901     05 SW-PRIMEIRA-INVOCA         PIC X(01) VALUE SPACES.
              88 SW-PRIMEIRA-INVOCA-N              VALUE '0'.
              88 SW-PRIMEIRA-INVOCA-S              VALUE '1'.
      *--------------------------------------------------------------
      *            VARIAVEIS
      *--------------------------------------------------------------
       01  WS-VARIAVEIS.
           05 WS-GDESC                   PIC  X(500)   VALUE SPACES.
           05 WS-BALCAO                  PIC  X(40)    VALUE SPACES.
           05 WS-HEADER-NOCB             PIC  9(09).
           05 WS-COD-OPER                PIC  9(03).
           05 WS-DESCRICAO               PIC  X(40).
           05 WS-CNTA-CCB                PIC  X(13).
           05 WS-IDSP                    PIC  X(01).
           05 WS-SLD-DISP-DO             PIC  S9(19)V99.
           05 WS-SLD-DISP-TOT            PIC  S9(19)V99.
           05 WS-MONTANTE                PIC  S9(19)V99.
           05 WS-MONTANTE-TOTAL          PIC  S9(19)V99.
           05 WS-MONT-CRED-TOT           PIC  S9(19)V99.
           05 WS-VALOR-CREDITOS          PIC  S9(19)V99.
           05 WS-VALOR-CRED-TEI          PIC  S9(19)V99.
           05 WS-VALOR-DESPESAS          PIC  S9(19)V99.
           05 WS-QUANT-CREDITOS          PIC  9(06).
           05 WS-QUANT-CRED-TEI          PIC  9(06).
           05 WS-CCOD                  PIC  X(01)    VALUE SPACES.
           05 WS-CNTA                  PIC  9(14)    VALUE ZEROES.
           05 WS-CNTA-R REDEFINES WS-CNTA.
              10 WS-NCLI               PIC  9(09)    VALUE ZEROES.
              10 WS-NATR               PIC  9(02)    VALUE ZEROES.
              10 WS-NSEQ               PIC  9(03)    VALUE ZEROES.
           05 WS-NIB.
              10 WS-CBAN               PIC  9(04)    VALUE ZEROES.
              10 WS-CBAL               PIC  9(04)    VALUE ZEROES.
              10 WS-CNTAN              PIC  9(11)    VALUE ZEROES.
              10 WS-CDIG               PIC  9(02)    VALUE ZEROES.
           05 WS-ERR.
              10 WS-ERR-DESC1          PIC  X(40)    VALUE SPACES.
           05 WS-ERR2.
              10 WS-ERR-DESC2          PIC  X(40)    VALUE SPACES.
           05 WS-INDICE                PIC  9(03)    VALUE ZEROES.
           05 WS-DINT-98               PIC  9(08)    VALUE ZEROES.
           05 WS-MORADA                PIC  X(40)    VALUE SPACES.
           05 WS-PROVINCIA             PIC  X(30)    VALUE SPACES.
           05 WS-REG-PROCESSADOS       PIC  9(14)    VALUE ZEROES.
           05 WS-MONTANT-PROCESS       PIC S9(13)V99 VALUE ZEROES.
           05 WS-REG-N-PROCESS         PIC  9(14)    VALUE ZEROES.
           05 WS-MONTANT-N-PROCE       PIC S9(13)V99 VALUE ZEROES.
           05 WS-TOTAL-REGISTOS        PIC  9(14)    VALUE ZEROES.
           05 WS-TOTAL-MONTANTE        PIC S9(13)V99 VALUE ZEROES.
           05 WS-TOTAL-COMISSOES       PIC S9(13)V99 VALUE ZEROES.
           05 WS-TOTAL-IMPOSTOS        PIC S9(13)V99 VALUE ZEROES.
           05 WS-TOTAL-DEBITOS         PIC S9(13)V99 VALUE ZEROES.
           05 WS-TOTAL-REG-INTERNOS    PIC S9(08)    VALUE ZEROES.
           05 WS-TOTAL-REG-OIC         PIC S9(08)    VALUE ZEROES.
           05 WS-DIM-SEQMV.
              10 WS-SEQMV OCCURS 100   PIC  9(02).
           05 WS-DIM-PACNT.
              10 WS-PACNT OCCURS 100   PIC  X(03).
           05 WS-DIM-BALC.
              10 WS-BALC  OCCURS 100   PIC  X(04).
           05 WS-DIM-CCB.
              10 WS-CCB   OCCURS 100   PIC  X(13).
           05 WS-DIM-COPER.
              10 WS-COPER OCCURS 100   PIC  9(03).
           05 WS-DIM-QOPER.
              10 WS-QOPER OCCURS 100   PIC  9(06).
           05 WS-DIM-VALOR.
              10 WS-VALOR OCCURS 100   PIC  S9(13)V99.
           05 WS-DIM-DESCR.
              10 WS-DESCR OCCURS 100   PIC  X(40).
           05 WS-DTSITU-TEI-ENVIADA    PIC  X(02).
           05 WS-DTSITU-TEI-COMUNICADA PIC  X(02).
           05 WS-DTSITU-TEI-RECUSADA   PIC  X(02).
      *--------------------------------------------------------------
      *            CONSTANTES
      *--------------------------------------------------------------
       01  WS-CONSTANTES.
           05 WS-PROGNAME              PIC  X(10)  VALUE 'PSI75900'.
           05 CON-PACNT-MOV-CNT-CCB    PIC  X(03)  VALUE 'C  '.
           05 CON-PSHEADER             PIC  X(08)  VALUE 'PSHEADER'.
           05 CON-PSHMENSA             PIC  X(08)  VALUE 'PSHMENSA'.
PRA        05 CON-PSMENSAG             PIC  X(08)  VALUE 'PSMENSAG'.
           05 CON-CODESTBL             PIC  X(08)  VALUE 'CODESTBL'.
           05 CON-PSDETALH             PIC  X(08)  VALUE 'PSDETALH'.
           05 CON-ARVT0500             PIC  X(08)  VALUE 'ARVT0500'.
           05 CON-PSM5250              PIC  X(10)  VALUE 'PSM5250'.
           05 CON-S                    PIC  X(01)  VALUE 'S'.
           05 CON-CLIENTE              PIC  X(01)  VALUE 'C'.
           05 CON-VIGENTE              PIC  X(01)  VALUE 'V'.
           05 CON-PROCESSADO           PIC  X(02)  VALUE 'PR'.
           05 CON-ENVIADO-TEI          PIC  X(02)  VALUE 'ET'.
      *--------------------------------------------------------------
      *              DECLARACOES DE CURSORES DB2                     *
      *--------------------------------------------------------------
      *
       01  WS-CURSOR-VARS.
           05 FILLER                     PIC X(01) VALUE SPACES.
           EXEC SQL
              DECLARE CURPST01 CURSOR FOR
                 SELECT DTNCLI
                      , DTDINT
                      , DTNFIC
                      , DTNREG
                      , DTREF
                      , DTTREG
                      , DTTOPE
                      , DTSITC
                      , DTSITR
                      , DTCBAN
                      , DTCBAL
                      , DTCNTA
                      , DTCDIG
                      , DTMONT
                      , DTNOME
                      , DTREFTR
                      , DTDVAL
                      , DTNTRY
                      , DTNOCB
                      , DTSITU
                      , DTMAIL
                   FROM PSDETALHE
                  WHERE DTNCLI  = :PSDETALHE-DTNCLI
                    AND DTDINT  = :PSDETALHE-DTDINT
                    AND DTNFIC  = :PSDETALHE-DTNFIC
                    AND DTNREG >= :PSDETALHE-DTNREG
                    AND DTSITU NOT IN ("PR", "ET")
      *             AND DTSITU <> :PSDETALHE-DTSITU
               ORDER BY DTNCLI
                      , DTDINT
                      , DTNFIC
                      , DTNREG
           END-EXEC.

      *--------------------------------------------------------------
       01  FILLER                        PIC X(40) VALUE
           'FIM DA WORKING-STORAGE PSI75900         '.
      *--------------------------------------------------------------
       LINKAGE SECTION.
      *--------------------------------------------------------------
      *
       COPY VIAL0004.
      *
            EXEC SQL INCLUDE VIAP0009 END-EXEC.
      *
      *--------------------------------------------------------------
      *            0000-MAINLINE
      *--------------------------------------------------------------
       0000-MAINLINE.
      *
           PERFORM 1000-INICIO-PROGRAMA
              THRU 1099-INICIO-PROGRAMA-EXIT.

           PERFORM 2000-PROC-PROGRAMA
              THRU 2099-PROC-PROGRAMA-EXIT.

           PERFORM 3000-FINAL-PROGRAMA
              THRU 3099-FINAL-PROGRAMA-EXIT.
      *
       0099-MAINLINE-EXIT.
           COPY VIAP0004.
      *--------------------------------------------------------------
      *            1000-INICIO-PROGRAMA
      *--------------------------------------------------------------
       1000-INICIO-PROGRAMA.
      *
           SET  VIAL0001-DEBUG-SIM         TO TRUE.
           IF VIAL0001-DEBUG-SIM
              MOVE '????-INICIO-PROGRAMA' TO VIAL0015-CALLER-ID
              MOVE 'VIAL0001-VERSAO-SYS'   TO VIAL0015-CAMPO-NM(1)
              MOVE VIAL0001-VERSAO-SYS     TO VIAL0015-CAMPO-VLR(1)
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.
      *
           MOVE VIAL0001-MENSAGEM-INPUT    TO PSCV7590-MSG.
           MOVE PSCV7590-ASE               TO PSCV7591-ASE.
      *
           MOVE ZEROES                     TO PSCV7591-INDICE.
           PERFORM 1100-LIMPA-OCCURS
              THRU 1199-LIMPA-OCCURS-EXIT
             UNTIL PSCV7591-PAGINA-CHEIA.
      *
       1099-INICIO-PROGRAMA-EXIT.
           EXIT.
      *--------------------------------------------------------------
      *            1100-LIMPA-OCCURS
      *--------------------------------------------------------------
       1100-LIMPA-OCCURS.
      *
           ADD 1                       TO PSCV7591-INDICE.
           MOVE ZEROES
             TO PSCV7591-D-ORNCLI(PSCV7591-INDICE)
           MOVE SPACES
             TO PSCV7591-D-ORDINT(PSCV7591-INDICE)
           MOVE ZEROES
             TO PSCV7591-D-ORNFIC(PSCV7591-INDICE)
           MOVE ZEROES
             TO PSCV7591-D-ORNREG(PSCV7591-INDICE)
           MOVE SPACES
             TO PSCV7591-D-ORBNOM(PSCV7591-INDICE)
           MOVE SPACES
             TO PSCV7591-D-ORBNIB(PSCV7591-INDICE)
           MOVE ZEROES
             TO PSCV7591-D-ORBMNT(PSCV7591-INDICE)
           MOVE SPACES
             TO PSCV7591-D-ORBERR1(PSCV7591-INDICE)
      *
           .
       1199-LIMPA-OCCURS-EXIT.
           EXIT.
      *--------------------------------------------------------------
      *            2000-PROC-PROGRAMA
      *--------------------------------------------------------------
       2000-PROC-PROGRAMA.
      *
           IF VIAL0001-DEBUG-SIM
              MOVE '-------------------' TO VIAL0015-CALLER-ID
              MOVE PSCV7590-ORNCLI       TO VIAL0015-CAMPO-NM (1)
              MOVE PSCV7590-ORDINT       TO VIAL0015-CAMPO-VLR(1)
              MOVE PSCV7590-ORNFIC       TO VIAL0015-CAMPO-NM (2)
              MOVE PSCV7590-ORNREG       TO VIAL0015-CAMPO-VLR(2)
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.
AR0901*
AR0901     IF PSCV7590-ORNREG EQUAL ZEROES
AR0901        SET SW-PRIMEIRA-INVOCA-S     TO TRUE
AR0901     ELSE
AR0901        SET SW-PRIMEIRA-INVOCA-N     TO TRUE
AR0901     END-IF.
      *
           MOVE PSCV7590-ORNCLI
             TO PSCV7591-ORNCLI
           MOVE PSCV7590-ORNMCLI
             TO PSCV7591-ORNMCLI
           MOVE PSCV7590-ORDINT
             TO PSCV7591-ORDINT
           MOVE PSCV7590-ORNFIC
             TO PSCV7591-ORNFIC
           MOVE PSCV7590-ORNFICH
             TO PSCV7591-ORNFICH
           MOVE PSCV7590-ORBIBLI
             TO PSCV7591-ORBIBLI
           MOVE PSCV7590-ORNREG
             TO PSCV7591-ORNREG
           MOVE PSCV7590-ORMOR1
             TO PSCV7591-ORMOR1
           MOVE PSCV7590-ORPROV
             TO PSCV7591-ORPROV
           MOVE PSCV7590-ORBALC
             TO PSCV7591-ORBALC
           MOVE PSCV7590-ORCONTA
             TO PSCV7591-ORCONTA
           MOVE PSCV7590-ORDPRC
             TO PSCV7591-ORDPRC
           MOVE PSCV7590-ORMOED
             TO PSCV7591-ORMOED
           MOVE PSCV7590-ORTOTS
             TO PSCV7591-ORTOTS
           MOVE PSCV7590-ORTCOM
             TO PSCV7591-ORTCOM
           MOVE PSCV7590-ORISEL
             TO PSCV7591-ORISEL
           MOVE PSCV7590-ORVDEB
             TO PSCV7591-ORVDEB
           MOVE PSCV7590-ORDESC
             TO PSCV7591-ORDESC
           MOVE PSCV7590-ORREFE
             TO PSCV7591-ORREFE
           MOVE PSCV7590-ORRPROC
             TO PSCV7591-ORRPROC
           MOVE PSCV7590-ORRNPRC
             TO PSCV7591-ORRNPRC
           MOVE PSCV7590-ORRTPRC
             TO PSCV7591-ORRTPRC
           MOVE PSCV7590-ORVPROC
             TO PSCV7591-ORVPROC
           MOVE PSCV7590-ORVNPRC
             TO PSCV7591-ORVNPRC
           MOVE PSCV7590-ORVTPRC
             TO PSCV7591-ORVTPRC
      *
           PERFORM 2005-TRATA-DADOS
              THRU 2005-TRATA-DADOS-EXIT.
      *
           IF VIAL0001-DEBUG-SIM
              MOVE '-------------------'   TO VIAL0015-CALLER-ID
              MOVE 'PSCV7591-INDICE '      TO VIAL0015-CAMPO-NM (1)
              MOVE  PSCV7591-INDICE        TO VIAL0015-CAMPO-VLR(1)
              MOVE 'VIAL0002-IND-ERROS'    TO VIAL0015-CAMPO-NM (2)
              MOVE  VIAL0002-IND-ERROS     TO VIAL0015-CAMPO-VLR(2)
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.
      *
           IF VIAL0002-SEM-ERROS
           OR VIAL0002-FIM-CONSULTA
             MOVE SPACES                   TO PSCL5700-TTR
    ****QUANDO EXISTEM MAIS DE 70 REGISTOS
             IF VIAL0002-SEM-ERROS
AR0901         IF SW-PRIMEIRA-INVOCA-S
AR0901           PERFORM 7400-VALIDA-DUPLICADO
AR0901              THRU 7400-VALIDA-DUPLICADO-EXIT
AR0901         END-IF
               SET PSCL5700-TTR-INSERE   TO TRUE
               PERFORM 7000-REGISTA-EMISSAO
                  THRU 7000-REGISTA-EMISSAO-EXIT
             END-IF

    ****QUANDO EXISTEM MENOS DE 70 REGISTOS
             IF VIAL0002-FIM-CONSULTA
             AND NOT PSCV7591-PAGINA-CHEIA
                SET VIAL0002-SEM-ERROS     TO TRUE
AR0901          IF SW-PRIMEIRA-INVOCA-S
AR0901            PERFORM 7400-VALIDA-DUPLICADO
AR0901               THRU 7400-VALIDA-DUPLICADO-EXIT
AR0901         END-IF
                SET PSCL5700-TTR-INSERE    TO TRUE
                PERFORM 7000-REGISTA-EMISSAO
                   THRU 7000-REGISTA-EMISSAO-EXIT
                SET PSCL5700-TTR-DETALHES  TO TRUE
                SET VIAL0002-SEM-ERROS     TO TRUE
                PERFORM 7000-REGISTA-EMISSAO
                   THRU 7000-REGISTA-EMISSAO-EXIT
             END-IF

    ****QUANDO EXISTEM MAIS DE 70 REGISTOS E JÁ TERMINOU
             IF VIAL0002-FIM-CONSULTA
             AND PSCV7591-PAGINA-CHEIA
                SET PSCL5700-TTR-DETALHES  TO TRUE
                SET VIAL0002-SEM-ERROS     TO TRUE
                PERFORM 7000-REGISTA-EMISSAO
                   THRU 7000-REGISTA-EMISSAO-EXIT
             END-IF
AR0901*
    ****SE FIM DE CONSULTA VAI COBRAR A COMISSAO
AR0901*      IF VIAL0002-FIM-CONSULTA
AR0901*        PERFORM 7400-VALIDA-DUPLICADO
AR0901*           THRU 7400-VALIDA-DUPLICADO-EXIT
    ****FORCA FIM DE CONSULTA PARA NAO SER CHAMADO NOVAMENTE
AR0901*        IF VIAL0002-SEM-ERROS
AR0901*          SET VIAL0002-FIM-CONSULTA TO TRUE
AR0901*        END-IF
AR0901*      END-IF
      *
      * SE CORREU TUDO BEM NO REGISTO DE DADOS DO BORDEREAUX E SE
      * O CODIGO DE TRANSACÇĂO É O DE INSERÇĂO SÓ DE DETALHES, ENTĂO
      * REPŐE O VIAL0002-FIM-CONSULTA, PARA QUE O LOCAL SAIBA QUE
      * AINDA EXISTEM MAIS REGISTOS
      *
             IF VIAL0002-SEM-ERROS
               IF PSCL5700-TTR-DETALHES
                 SET VIAL0002-FIM-CONSULTA TO TRUE
               END-IF
             END-IF
           END-IF.
      *
       2099-PROC-PROGRAMA-EXIT.
           EXIT.

      *--------------------------------------------------------------
      *                   2005-TRATA-DADOS
      *--------------------------------------------------------------
       2005-TRATA-DADOS.
      *
           PERFORM 2010-VALIDACOES
              THRU 2019-VALIDACOES-EXIT.
      *
           IF VIAL0002-SEM-ERROS
              PERFORM 2100-TRATA-HEADER
                 THRU 2100-TRATA-HEADER-EXIT
           END-IF.
      *
           IF VIAL0002-SEM-ERROS
              PERFORM 2020-OPEN
                 THRU 2029-OPEN-EXIT
           END-IF.
      *
           IF VIAL0002-SEM-ERROS
              PERFORM 2030-FETCH
                 THRU 2039-FETCH-EXIT
      *
              IF VIAL0002-SEM-ERROS
                 IF DB2-OK
                    PERFORM 2040-CONTINUA
                       THRU 2049-CONTINUA-EXIT
                 ELSE
                    COMPUTE PSCV7591-DIMINUI-LENGTH EQUAL
                         PSCV7591-INDICE-INVERSO * PSCV7591-LENGTH-OCCUR
                    COMPUTE PSCV7591-LENGTH EQUAL PSCV7591-LENGTH
                         - PSCV7591-DIMINUI-LENGTH
ES                  MOVE ZEROES TO PSCV7591-INDICE
ES                  SET  VIAL0002-FIM-CONSULTA TO TRUE
                 END-IF
              END-IF
              PERFORM 2070-CLOSE
                 THRU 2079-CLOSE-EXIT
           END-IF.
      *
       2005-TRATA-DADOS-EXIT.
           EXIT.

      *--------------------------------------------------------------
      *                   2010-VALIDACOES
      *--------------------------------------------------------------
       2010-VALIDACOES.
      *
           IF VIAL0001-DEBUG-SIM
              MOVE '2010-VALIDACOES' TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.

           IF PSCV7590-ORNCLI NOT NUMERIC
              MOVE ZEROES                  TO PSCV7590-ORNCLI
           END-IF.
           IF PSCV7590-ORNCLI EQUAL ZEROES
              SET  VIAL0002-ERROS-FUNCAO   TO TRUE
              MOVE PSCK0002-STATUS-ACTIVO  TO PSCV7591-ORNCLI-S
              MOVE PSCK0002-CAPLIC-PS      TO PSCV7591-ORNCLI-CAPLIC
              MOVE PSCK0001-NCLI-OBRG      TO PSCV7591-ORNCLI-MSG
           END-IF.
      *
           IF PSCV7590-ORDINT EQUAL SPACES     OR
              PSCV7590-ORDINT EQUAL LOW-VALUES OR
              PSCV7590-ORDINT EQUAL HIGH-VALUES

              SET  VIAL0002-ERROS-FUNCAO   TO TRUE
              MOVE PSCK0002-STATUS-ACTIVO  TO PSCV7591-ORDINT-S
              MOVE PSCK0002-CAPLIC-PS      TO PSCV7591-ORDINT-CAPLIC
              MOVE PSCK0001-DINT-OBRG      TO PSCV7591-ORDINT-MSG
           ELSE
              MOVE PSCV7590-ORDINT         TO AQCW0005-DTX10

              PERFORM AQCP0005-CONV-DT10INDT8
                 THRU AQCP0005-CONV-DT10INDT8-EXIT

              MOVE AQCW0005-DT98           TO WS-DINT-98
           END-IF.
      *
           IF PSCV7590-ORNFIC NOT NUMERIC
              MOVE ZEROES                  TO PSCV7590-ORNFIC
           END-IF.
           IF PSCV7590-ORNFIC EQUAL ZEROES
              SET  VIAL0002-ERROS-FUNCAO   TO TRUE
              MOVE PSCK0002-STATUS-ACTIVO  TO PSCV7591-ORNFIC-S
              MOVE PSCK0002-CAPLIC-PS      TO PSCV7591-ORNFIC-CAPLIC
              MOVE PSCK0001-NCLI-OBRG      TO PSCV7591-ORNFIC-MSG
           END-IF.

           IF PSCV7590-ORNREG NOT NUMERIC
              MOVE ZEROES                  TO PSCV7590-ORNREG
           END-IF.

           CONTINUE.
      *
       2019-VALIDACOES-EXIT.
           EXIT.

      *--------------------------------------------------------------
      *                   2100-TRATA-HEADER
      *--------------------------------------------------------------
       2100-TRATA-HEADER.
      *
           IF VIAL0001-DEBUG-SIM
              MOVE '2100-TRATA-HEADER'     TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.
      *
           IF VIAL0002-SEM-ERROS
              PERFORM 2110-MOVE-PARA-OUT
                 THRU 2110-MOVE-PARA-OUT-EXIT
           END-IF.
      *
           IF VIAL0002-SEM-ERROS
              PERFORM 2120-OBTEM-HEADER
                 THRU 2120-OBTEM-HEADER-EXIT
           END-IF.
      *
ESNEW      IF VIAL0002-SEM-ERROS
ESNEW         PERFORM 2125-VERIFICA-SITC
ESNEW            THRU 2125-VERIFICA-SITC-EXIT
ESNEW      END-IF.
      *
           IF VIAL0002-SEM-ERROS
              PERFORM 2130-NOME-CLIENTE
                 THRU 2130-NOME-CLIENTE-EXIT
           END-IF.
      *
           IF VIAL0002-SEM-ERROS
              PERFORM 2140-MORADA-CLIENTE
                 THRU 2140-MORADA-CLIENTE-EXIT
           END-IF.
      *
           MOVE ZEROES                     TO WS-INDICE.
           PERFORM 2142-CONSULTA-MORADA
              THRU 2142-CONSULTA-MORADA-EXIT
             UNTIL WS-INDICE >= 50
                OR NOT VIAL0002-SEM-ERROS.
      *
           IF VIAL0002-SEM-ERROS
              PERFORM 2160-TOTAL-TRANSFERIDO
                 THRU 2160-TOTAL-TRANSFERIDO-EXIT
           END-IF.
      *
           IF VIAL0002-SEM-ERROS
              PERFORM 2170-TOTAL-N-TRANSFERIDO
                 THRU 2170-TOTAL-N-TRANSFERIDO-EXIT
           END-IF.
      *
           IF VIAL0002-SEM-ERROS
              PERFORM 4000-TOTAL-REG-INTERNOS
                 THRU 4000-TOTAL-REG-INTERNOS-EXIT
           END-IF.

           IF VIAL0002-SEM-ERROS
              PERFORM 4100-TOTAL-REG-OIC
                 THRU 4100-TOTAL-REG-OIC-EXIT
           END-IF.
      *
           IF VIAL0002-SEM-ERROS
              PERFORM 2150-CALCULA-COMISSOES
                 THRU 2150-CALCULA-COMISSOES-EXIT
           END-IF.
      *
           IF VIAL0002-SEM-ERROS
              PERFORM 2190-DESCRITIVO-BALCAO
                 THRU 2190-DESCRITIVO-BALCAO-EXIT
           END-IF.
      *
           IF VIAL0002-SEM-ERROS
              PERFORM 2180-FORMATA-FICHEIRO
                 THRU 2180-FORMATA-FICHEIRO-EXIT
           END-IF.
      *
       2100-TRATA-HEADER-EXIT.
           EXIT.
      *--------------------------------------------------------------
      *                     2110-MOVE-PARA-OUT
      *--------------------------------------------------------------
       2110-MOVE-PARA-OUT.
      *
           IF VIAL0001-DEBUG-SIM
              MOVE '2110-MOVE-PARA-OUT'    TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.
      *
           MOVE PSCV7590-ORNCLI            TO PSCV7591-ORNCLI .
           MOVE PSCV7590-ORNMCLI           TO PSCV7591-ORNMCLI.
           MOVE PSCV7590-ORDINT            TO PSCV7591-ORDINT .
           MOVE PSCV7590-ORNFIC            TO PSCV7591-ORNFIC .
           MOVE PSCV7590-ORNREG            TO PSCV7591-ORNREG .
           MOVE PSCV7590-ORMOR1            TO PSCV7591-ORMOR1 .
           MOVE PSCV7590-ORPROV            TO PSCV7591-ORPROV .
           MOVE PSCV7590-ORBALC            TO PSCV7591-ORBALC .
           MOVE PSCV7590-ORCONTA           TO PSCV7591-ORCONTA.
           MOVE PSCV7590-ORDPRC            TO PSCV7591-ORDPRC .
           MOVE PSCV7590-ORMOED            TO PSCV7591-ORMOED .
           MOVE PSCV7590-ORTOTS            TO PSCV7591-ORTOTS .
           MOVE PSCV7590-ORTCOM            TO PSCV7591-ORTCOM .
           MOVE PSCV7590-ORISEL            TO PSCV7591-ORISEL .
           MOVE PSCV7590-ORVDEB            TO PSCV7591-ORVDEB .
           MOVE PSCV7590-ORDESC            TO PSCV7591-ORDESC .
           MOVE PSCV7590-ORREFE            TO PSCV7591-ORREFE .
           MOVE PSCV7590-ORRPROC           TO PSCV7591-ORRPROC.
           MOVE PSCV7590-ORRNPRC           TO PSCV7591-ORRNPRC.
           MOVE PSCV7590-ORRTPRC           TO PSCV7591-ORRTPRC.
           MOVE PSCV7590-ORVPROC           TO PSCV7591-ORVPROC.
           MOVE PSCV7590-ORVNPRC           TO PSCV7591-ORVNPRC.
           MOVE PSCV7590-ORVTPRC           TO PSCV7591-ORVTPRC.
      *
       2110-MOVE-PARA-OUT-EXIT.
           EXIT.
      *--------------------------------------------------------------
      *                     2120-OBTEM-HEADER
      *--------------------------------------------------------------
       2120-OBTEM-HEADER.
      *
           IF VIAL0001-DEBUG-SIM
              MOVE '2120-OBTEM-HEADER'     TO VIAL0015-CALLER-ID
              MOVE 'PSCV7590-ORNCLI  '     TO VIAL0015-CAMPO-NM(1)
              MOVE PSCV7590-ORNCLI         TO VIAL0015-CAMPO-VLR(1)
              MOVE 'WS-DINT-98       '     TO VIAL0015-CAMPO-NM(2)
              MOVE WS-DINT-98              TO VIAL0015-CAMPO-VLR(2)
              MOVE 'PSCV7590-ORNFIC  '     TO VIAL0015-CAMPO-NM(3)
              MOVE PSCV7590-ORNFIC         TO VIAL0015-CAMPO-VLR(3)
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.
      *
           INITIALIZE REG-PSHEADER.
           MOVE PSCV7590-ORNCLI            TO PSHEADER-HRNCLI.
           MOVE WS-DINT-98                 TO PSHEADER-HRDINT.
           MOVE PSCV7590-ORNFIC            TO PSHEADER-HRNFIC.
      *
           EXEC SQL
                SELECT  HRREF
                     ,  HRTREG
                     ,  HRTOPE
                     ,  HRSITC
                     ,  HRSITR
                     ,  HRCBAN
                     ,  HRCBAL
                     ,  HRCNTA
                     ,  HRCDIG
                     ,  HRMOED
                     ,  HRDPRO
                     ,  HRREFORD
                     ,  HRDVAL
                     ,  HRNTRY
                     ,  HRNOCB
                     ,  HRANUL
                     ,  HRSITU
                     ,  HRMAIL
                     ,  HROGER
                     ,  HRAGEN
                     ,  HRCANAL
                     ,  HRTREMUN
                  INTO :PSHEADER-HRREF
                     , :PSHEADER-HRTREG
                     , :PSHEADER-HRTOPE
                     , :PSHEADER-HRSITC
                     , :PSHEADER-HRSITR
                     , :PSHEADER-HRCBAN
                     , :PSHEADER-HRCBAL
                     , :PSHEADER-HRCNTA
                     , :PSHEADER-HRCDIG
                     , :PSHEADER-HRMOED
                     , :PSHEADER-HRDPRO
                     , :PSHEADER-HRREFORD
                     , :PSHEADER-HRDVAL
                     , :PSHEADER-HRNTRY
                     , :PSHEADER-HRNOCB
                     , :PSHEADER-HRANUL
                     , :PSHEADER-HRSITU
                     , :PSHEADER-HRMAIL
                     , :PSHEADER-HROGER
                     , :PSHEADER-HRAGEN
                     , :PSHEADER-HRCANAL
                     , :PSHEADER-HRTREMUN
                  FROM  PSHEADER3
                 WHERE  HRNCLI = :PSHEADER-HRNCLI
                   AND  HRDINT = :PSHEADER-HRDINT
                   AND  HRNFIC = :PSHEADER-HRNFIC
           END-EXEC.

           IF VIAL0001-DEBUG-SIM
              MOVE '****-OBTEM-HEADER'     TO VIAL0015-CALLER-ID
              MOVE 'SQLCODE          '     TO VIAL0015-CAMPO-NM(1)
              MOVE SQLCODE                 TO VIAL0015-CAMPO-VLR(1)
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.

           MOVE CON-PSHEADER               TO VIAL0002-TABLE-NAME.

           PERFORM 9020-DB2CHECK
              THRU 9029-DB2CHECK-EXIT.
      *
       2120-OBTEM-HEADER-EXIT.
           EXIT.
      *
      *--------------------------------------------------------------
      *                     2125-VERIFICA-SITC
      *--------------------------------------------------------------
       2125-VERIFICA-SITC.
      *
           IF VIAL0001-DEBUG-SIM
              MOVE '2125-VERIFICA-SITC'    TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.
      *
      * SE O SITC DO ORDENANTE <> 0 VAI DESCODIFICAR O CÓDIGO DO ERRO
      *
           EVALUATE PSHEADER-HRSITC
              WHEN PSCK0002-SITC-NORMAL
                 MOVE PSCK0002-CCOD-ORD-OK  TO WS-CCOD
              WHEN OTHER
                 MOVE PSCK0002-TAB-SITC     TO ARCD0500-CTABELA
                 MOVE PSHEADER-HRSITC       TO ARCD0500-CCOD
                 MOVE SPACES                TO ARCD0500-C2COD
                 MOVE PSCK0002-PT-PT        TO ARCD0500-CLINGUA
                 PERFORM 2126-CONSULTA-CODIGO
                    THRU 2126-CONSULTA-CODIGO-EXIT
                 MOVE ARCD0500-GDESC        TO WS-GDESC
                 MOVE PSCK0002-CCOD-ORD-NOK TO WS-CCOD
           END-EVALUATE.
      *
      * VAI OBTER O TEXTO DO MOTIVO, CONSOANTE O VALOR DO SITC
      * EXISTE UM TEXTO PATA SITC = 00 E OUTRO PARA OS RESTANTES CASOS
      *
           IF VIAL0002-SEM-ERROS
              MOVE PSCK0002-TAB-MOTIVOS     TO ARCD0500-CTABELA
              MOVE WS-CCOD                  TO ARCD0500-CCOD
              MOVE SPACES                   TO ARCD0500-C2COD
              MOVE PSCK0002-PT-PT           TO ARCD0500-CLINGUA
              PERFORM 2126-CONSULTA-CODIGO
                 THRU 2126-CONSULTA-CODIGO-EXIT
           END-IF.
      *
      * QUANDO SITC = 00 APENAS VAI OBTER O TEXTO E DEVOLVE
      * SE SITC <> 00 OBTEM TEXTO E CONCATENA COM A DESCRIÇĂO DO SITC
      *
           IF VIAL0002-SEM-ERROS
              EVALUATE WS-CCOD
                WHEN PSCK0002-CCOD-ORD-OK
                  MOVE ARCD0500-GDESC       TO PSCV7591-ORMOTIV
                WHEN PSCK0002-CCOD-ORD-NOK
                  STRING ARCD0500-GDESC DELIMITED '  '
                         ' '            DELIMITED BY SIZE
                         WS-GDESC       DELIMITED '  '
                    INTO PSCV7591-ORMOTIV
              END-EVALUATE
           END-IF.
      *
           IF VIAL0001-DEBUG-SIM
              MOVE '****-MOTIVO       '    TO VIAL0015-CALLER-ID
              MOVE PSCV7591-ORMOTIV        TO VIAL0015-CAMPOS-CHAVE
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.
      *
       2125-VERIFICA-SITC-EXIT.
           EXIT.

      *--------------------------------------------------------------
      *                     2126-CONSULTA-CODIGO
      *--------------------------------------------------------------
       2126-CONSULTA-CODIGO.
      *
           IF VIAL0001-DEBUG-SIM
              MOVE '2126-CONSULTA-CODIGO'    TO VIAL0015-CALLER-ID
              MOVE ARCD0500-CCOD             TO VIAL0015-CAMPO-NM(1)
              MOVE ARCD0500-CTABELA          TO VIAL0015-CAMPO-VLR(1)
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.
      *
           MOVE SPACES
             TO ARCD0500-GDESC

           EXEC SQL
             SELECT GDESC
               INTO :ARCD0500-GDESC
               FROM ARVT0500_CODESTABLE
              WHERE CTABELA = :ARCD0500-CTABELA
                AND    CCOD = :ARCD0500-CCOD
                AND   C2COD = :ARCD0500-C2COD
                AND CLINGUA = :ARCD0500-CLINGUA
           END-EXEC.

           MOVE CON-ARVT0500
             TO VIAL0002-TABLE-NAME.

           PERFORM 9020-DB2CHECK
              THRU 9029-DB2CHECK-EXIT.

           IF VIAL0002-SEM-ERROS
              IF DB2-OK
                 CONTINUE
              ELSE
                 MOVE VIAK0002-ERROS-FUNCAO
                   TO VIAL0002-IND-ERROS
                 MOVE PSCK0002-STATUS-ACTIVO
                   TO PSCV7590-ORNFIC-S
                 MOVE PSCK0001-ERR-SITC
                   TO PSCV7590-ORNFIC-MSG
              END-IF
           END-IF.
      *
           MOVE CON-PSHEADER               TO VIAL0002-TABLE-NAME.

           PERFORM 9020-DB2CHECK
              THRU 9029-DB2CHECK-EXIT.
      *
       2126-CONSULTA-CODIGO-EXIT.
           EXIT.

      *--------------------------------------------------------------
      *                   2130-NOME-CLIENTE
      *--------------------------------------------------------------
       2130-NOME-CLIENTE.
      *
           IF VIAL0001-DEBUG-SIM
              MOVE '2130-NOME-CLIENTE'     TO VIAL0015-CALLER-ID
              MOVE 'PSCV7590-ORNCLI  '     TO VIAL0015-CAMPO-NM (1)
              MOVE  PSCV7590-ORNCLI        TO VIAL0015-CAMPO-VLR(1)
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.
      * Nome do cliente:
           INITIALIZE SXCL0380-DATA.
AR0902*    INITIALIZE SXCL0002-COMMAREA.

           MOVE VIAL0001-VERSAO-SYS        TO SXCL0380-VERSAO
           MOVE VIAL0001-PGMID             TO SXCL0380-PGMC.
           MOVE PSCK0002-TTR-NOME-CLI      TO SXCL0380-TTR.
           MOVE VIAL0001-CALLERID          TO SXCL0380-JOBNC.
           MOVE VIAL0001-CUSER-EXTRN       TO SXCL0380-USERC.
           MOVE VIAL0001-MSGQ              TO SXCL0380-PGMQC.
           MOVE PSCK0002-RCODE-OK          TO SXCL0380-RCODE.
           MOVE PSCK0002-ESTR-NEXE         TO SXCL0380-ESTR.
           MOVE PSCK0002-APTR-APL          TO SXCL0380-APTR.
           MOVE PSCK0002-HCLI-VMSG         TO SXCL0380-HCLI.
           MOVE PSCK0002-VNCR-NVAL         TO SXCL0380-VNCR.
           MOVE ZEROES                     TO SXCL0380-CLBAL.
           MOVE PSCV7590-ORNCLI            TO SXCL0380-CLNCLI.

           CALL   SXCL0380-ROTINA USING  SXCL0002-COMMAREA
                                         SXCL0380-DATA.

           MOVE SXCL0380-RCODE             TO VIAW0020-RCODE.

           PERFORM VIAP0020-TRATA-RCODE
              THRU VIAP0020-TRATA-RCODE-EXIT.

           IF VIAL0002-SEM-ERROS AND
              SXCL0002-SEM-ERROS

              MOVE PSCV7590-ORNCLI         TO PSCV7591-ORNCLI
              MOVE SXCL0380-DWT OF SXCL0380-WT OF SXCL0380-DATA(1)
                                           TO PSCV7591-ORNMCLI
           ELSE
              SET  VIAL0002-ERROS-FUNCAO   TO TRUE
              MOVE PSCK0002-STATUS-ACTIVO  TO PSCV7591-ORNCLI-S
              MOVE PSCK0002-CAPLIC-PS      TO PSCV7591-ORNCLI-CAPLIC
              MOVE PSCK0001-ERR-HRNCLI     TO PSCV7591-ORNCLI-MSG
           END-IF.
      *
       2130-NOME-CLIENTE-EXIT.
           EXIT.

      *--------------------------------------------------------------
      *                   2140-MORADA-CLIENTE
      *--------------------------------------------------------------
       2140-MORADA-CLIENTE.
      *
           IF VIAL0001-DEBUG-SIM
              MOVE '2140-MORADA-CLIENTE'   TO VIAL0015-CALLER-ID
              MOVE  SXCL0610-DATA          TO VIAL0015-CAMPOS-CHAVE
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
              MOVE  SPACES                 TO VIAL0015-CAMPOS-CHAVE
           END-IF.
      *
      * Morada do cliente:
           INITIALIZE SXCL0610-DATA.
           INITIALIZE SXCL0002-COMMAREA.
      *
           MOVE VIAL0001-VERSAO-SYS        TO SXCL0610-VERSAO.
           SET  SXCL0610-CONS-MOR-CLI      TO TRUE.
           SET  SXCL0610-RCODE-OK          TO TRUE.
           SET  SXCL0610-ESTR-NEXE         TO TRUE.
           SET  SXCL0610-APTR-APL          TO TRUE.
           SET  SXCL0610-HCLI-VM           TO TRUE.
           SET  SXCL0610-VNCR-NAO          TO TRUE.
      *
           MOVE VIAL0001-PGMID             TO SXCL0610-PGMC .
           MOVE VIAL0001-CALLERID          TO SXCL0610-JOBNC.
           MOVE VIAL0001-CUSER-EXTRN       TO SXCL0610-USERC.
           MOVE VIAL0001-MSGQ              TO SXCL0610-PGMQC.
           MOVE PSCV7590-ORNCLI            TO SXCL0610-NCLI.
      *
           CALL   SXCL0610-ROTINA      USING  SXCL0002-COMMAREA
                                              SXCL0610-DATA.
      *
           MOVE SXCL0610-RCODE             TO VIAW0020-RCODE.

           PERFORM VIAP0020-TRATA-RCODE
              THRU VIAP0020-TRATA-RCODE-EXIT.

           IF VIAL0002-SEM-ERROS AND
              SXCL0002-SEM-ERROS

              CONTINUE
           ELSE
              SET  VIAL0002-ERROS-FUNCAO   TO TRUE
              MOVE PSCK0002-STATUS-ACTIVO  TO PSCV7591-ORNCLI-S
              MOVE PSCK0002-CAPLIC-PS      TO PSCV7591-ORNCLI-CAPLIC
              MOVE PSCK0001-ERR-HRNCLI     TO PSCV7591-ORNCLI-MSG
           END-IF.
      *
       2140-MORADA-CLIENTE-EXIT.
           EXIT.

      *******************************************************************
       2142-CONSULTA-MORADA.
      *******************************************************************
      *
           ADD 1                           TO WS-INDICE.
      *
           IF VIAL0001-DEBUG-SIM
              MOVE '2142-CONSULTA-MORADA'  TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
              MOVE  SPACES                 TO VIAL0015-CAMPOS-CHAVE
           END-IF.
      *
           IF  SXCL0610-WTMOR (WS-INDICE) = CON-CLIENTE
           AND SXCL0610-WSITU (WS-INDICE) = CON-VIGENTE
              MOVE SXCL0610-WMOR (WS-INDICE)  TO WS-MORADA
              MOVE SXCL0610-WMOR1(WS-INDICE)  TO WS-PROVINCIA
              MOVE 51                         TO WS-INDICE
           END-IF.
      *
       2142-CONSULTA-MORADA-EXIT.
           EXIT.
      *
      ******************************************************************
       2150-CALCULA-COMISSOES.
      ******************************************************************
           IF VIAL0001-DEBUG-SIM
              MOVE '2150-CALCULA-COMISSOES.' TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
              MOVE  SPACES                 TO VIAL0015-CAMPOS-CHAVE
           END-IF.
      *
           INITIALIZE PSCL5035-DATA.
           INITIALIZE SXCL0002-COMMAREA.
      *
           MOVE VIAL0001-PGMID             TO PSCL5035-PGMC.
           MOVE PSCK0002-TTR-VAZIO         TO PSCL5035-TTR.
           MOVE VIAL0001-CALLERID          TO PSCL5035-JOBNC.
           MOVE VIAL0001-CUSER-EXTRN       TO PSCL5035-USERC.
           MOVE VIAL0001-MSGQ              TO PSCL5035-PGMQC.
           MOVE PSCK0002-ESTR-NEXE         TO PSCL5035-ESTR.
           MOVE PSCK0002-APTR-APL          TO PSCL5035-APTR.
           MOVE PSCV7590-ORNCLI            TO PSCL5035-NCLI.
           MOVE WS-DINT-98                 TO PSCL5035-DINT.
           MOVE PSCV7590-ORNFIC            TO PSCL5035-NFIC.
           MOVE PSHEADER-HRMOED            TO PSCL5035-MOED.
           MOVE PSHEADER-HRCANAL           TO PSCL5035-CANAL.
           MOVE PSHEADER-HRTOPE            TO PSCL5035-TSERV.
           MOVE VIAL0001-CBANCO            TO PSCL5035-AT-CBAN .
           MOVE VIAL0001-CBALM             TO PSCL5035-AT-BALM .
           MOVE VIAL0001-DATA-EXTRN        TO PSCL5035-AT-DTOP .
           MOVE VIAL0001-CMOEDA            TO PSCL5035-AT-CMOE .
           MOVE VIAL0001-I-DEBUG           TO PSCL5035-AT-DEBUG.
      *
      *    CALL PSCK0002-PSM5035        USING PSCL5035-DATA.
      *
           PERFORM PSCP5035-CALL-PSM5035
              THRU PSCP5035-CALL-PSM5035-EXIT.
      *
           MOVE PSCL5035-RCODE             TO VIAW0020-RCODE.

           IF VIAL0001-DEBUG-SIM
              MOVE '***********************' TO VIAL0015-CALLER-ID
              MOVE PSCL5035-TOTAL            TO VIAL0015-CAMPO-NM(1)
              MOVE WS-REG-PROCESSADOS        TO VIAL0015-CAMPO-VLR(1)
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
              MOVE  SPACES                 TO VIAL0015-CAMPOS-CHAVE
           END-IF.
      *
           PERFORM VIAP0020-TRATA-RCODE
              THRU VIAP0020-TRATA-RCODE-EXIT.
      *
           IF VIAL0002-SEM-ERROS
              MOVE PSCL5035-TOTAL          TO WS-TOTAL-COMISSOES
              MOVE ZEROES                  TO WS-TOTAL-IMPOSTOS
           ELSE
              SET  VIAL0002-ERROS-FUNCAO   TO TRUE
              MOVE PSCK0002-STATUS-ACTIVO  TO PSCV7591-ORNCLI-S
              MOVE PSCK0002-CAPLIC-PS      TO PSCV7591-ORNCLI-CAPLIC
              MOVE PSCK0001-ERR-HRNCLI     TO PSCV7591-ORNCLI-MSG
           END-IF.

           IF VIAL0002-SEM-ERROS
             MOVE PSCL5035-SEQMV              TO WS-DIM-SEQMV
             MOVE PSCL5035-PACNT              TO WS-DIM-PACNT
             MOVE PSCL5035-COPER              TO WS-DIM-COPER
             MOVE PSCL5035-BALC               TO WS-DIM-BALC
             MOVE PSCL5035-CCB                TO WS-DIM-CCB
             MOVE PSCL5035-QOPER              TO WS-DIM-QOPER
             MOVE PSCL5035-VALOR              TO WS-DIM-VALOR
             MOVE PSCL5035-DESCR              TO WS-DIM-DESCR
           END-IF.

           MOVE ZEROES                TO WS-TOTAL-COMISSOES
           PERFORM 5150-CORRIGE-COMISSOES
              THRU 5150-CORRIGE-COMISSOES-EXIT
                VARYING WS-INDICE FROM 1 BY 1
                  UNTIL WS-INDICE > 100
                     OR NOT VIAL0002-SEM-ERROS.
      *
           IF VIAL0001-DEBUG-SIM
              MOVE '.......................' TO VIAL0015-CALLER-ID
              MOVE 'WS-TOTAL-COMISSOES     ' TO VIAL0015-CAMPO-NM(1)
              MOVE WS-TOTAL-COMISSOES        TO VIAL0015-CAMPO-VLR(1)
              MOVE 'WS-TOTAL-IMPOSTOS      ' TO VIAL0015-CAMPO-NM(2)
              MOVE WS-TOTAL-IMPOSTOS         TO VIAL0015-CAMPO-VLR(2)
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
              MOVE  SPACES                 TO VIAL0015-CAMPOS-CHAVE
           END-IF.
      *
            COMPUTE WS-TOTAL-COMISSOES = WS-TOTAL-COMISSOES -
                                         WS-TOTAL-IMPOSTOS.
      *
       2150-CALCULA-COMISSOES-EXIT.
           EXIT.
      *
      ******************************************************************
       2160-TOTAL-TRANSFERIDO.
      ******************************************************************
           IF VIAL0001-DEBUG-SIM
              MOVE '2160-TOTAL-TRANSFERIDO.' TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
              MOVE  SPACES                 TO VIAL0015-CAMPOS-CHAVE
           END-IF.
      *
           INITIALIZE RDETALHE.
           MOVE PSCV7590-ORNCLI                  TO PSDETALHE-DTNCLI.
           MOVE WS-DINT-98                       TO PSDETALHE-DTDINT.
           MOVE PSCV7590-ORNFIC                  TO PSDETALHE-DTNFIC.
           MOVE PSCK0002-REG-PROCESSADO          TO PSDETALHE-DTSITU.
      *
           EXEC SQL
              SELECT  IFNULL(COUNT(DTMONT), 0)
                   ,  IFNULL(  SUM(DTMONT), 0)
                INTO :PSDETALHE-DTNREG
                   , :PSDETALHE-DTMONT
                FROM  PSDETALHE
               WHERE  DTNCLI  = :PSDETALHE-DTNCLI
                 AND  DTDINT  = :PSDETALHE-DTDINT
                 AND  DTNFIC  = :PSDETALHE-DTNFIC
                 AND  DTSITU  IN (:CON-PROCESSADO, :CON-ENVIADO-TEI)
           END-EXEC.
      *
           MOVE CON-PSDETALH               TO VIAL0002-TABLE-NAME.

           PERFORM 9020-DB2CHECK
              THRU 9029-DB2CHECK-EXIT.
      *
           IF VIAL0002-SEM-ERROS
              MOVE PSDETALHE-DTNREG        TO WS-REG-PROCESSADOS
              MOVE PSDETALHE-DTMONT        TO WS-MONTANT-PROCESS
           ELSE
              MOVE PSCK0002-STATUS-ACTIVO  TO PSCV7591-ORNCLI-S
              MOVE PSCK0002-CAPLIC-PS      TO PSCV7591-ORNCLI-CAPLIC
              MOVE PSCK0001-ERR-HRNCLI     TO PSCV7591-ORNCLI-MSG
           END-IF.
      *
       2160-TOTAL-TRANSFERIDO-EXIT.
           EXIT.
      *
      ******************************************************************
       2170-TOTAL-N-TRANSFERIDO.
      ******************************************************************
           IF VIAL0001-DEBUG-SIM
              MOVE '2160-TOTAL-TRANSFERIDO.' TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
              MOVE  SPACES                 TO VIAL0015-CAMPOS-CHAVE
           END-IF.
      *
           INITIALIZE RDETALHE.
           MOVE PSCV7590-ORNCLI                  TO PSDETALHE-DTNCLI.
           MOVE WS-DINT-98                       TO PSDETALHE-DTDINT.
           MOVE PSCV7590-ORNFIC                  TO PSDETALHE-DTNFIC.
           MOVE PSCK0002-REG-PROCESSADO          TO PSDETALHE-DTSITU.
      *
           EXEC SQL
              SELECT IFNULL(COUNT(DTMONT), 0)
                   , IFNULL(  SUM(DTMONT), 0)
                INTO :PSDETALHE-DTNREG
                   , :PSDETALHE-DTMONT
                FROM PSDETALHE
               WHERE DTNCLI  = :PSDETALHE-DTNCLI
                 AND DTDINT  = :PSDETALHE-DTDINT
                 AND DTNFIC  = :PSDETALHE-DTNFIC
                 AND DTSITU NOT IN (:CON-PROCESSADO, :CON-ENVIADO-TEI)
           END-EXEC.
      *
           MOVE CON-PSDETALH               TO VIAL0002-TABLE-NAME.

           PERFORM 9020-DB2CHECK
              THRU 9029-DB2CHECK-EXIT.
      *
           IF VIAL0002-SEM-ERROS
              MOVE PSDETALHE-DTNREG        TO WS-REG-N-PROCESS
              MOVE PSDETALHE-DTMONT        TO WS-MONTANT-N-PROCE
           ELSE
              MOVE PSCK0002-STATUS-ACTIVO  TO PSCV7591-ORNCLI-S
              MOVE PSCK0002-CAPLIC-PS      TO PSCV7591-ORNCLI-CAPLIC
              MOVE PSCK0001-ERR-HRNCLI     TO PSCV7591-ORNCLI-MSG
           END-IF.
      *
       2170-TOTAL-N-TRANSFERIDO-EXIT.
           EXIT.
      *
      *--------------------------------------------------------------
      *                     2180-FORMATA-FICHEIRO
      *--------------------------------------------------------------
       2180-FORMATA-FICHEIRO.
      *
           COMPUTE WS-TOTAL-REGISTOS =
                   WS-REG-PROCESSADOS + WS-REG-N-PROCESS.
           COMPUTE WS-TOTAL-MONTANTE =
                   WS-MONTANT-PROCESS + WS-MONTANT-N-PROCE.
           COMPUTE WS-TOTAL-DEBITOS = WS-MONTANT-PROCESS +
                   WS-TOTAL-COMISSOES + WS-TOTAL-IMPOSTOS.
      *
           MOVE WS-MORADA                  TO PSCV7591-ORMOR1.
           MOVE WS-PROVINCIA               TO PSCV7591-ORPROV.
           IF WS-BALCAO EQUAL SPACES
              MOVE PSHEADER-HRAGEN         TO PSCV7591-ORBALC
           ELSE
              MOVE WS-BALCAO               TO PSCV7591-ORBALC
           END-IF
      *    MOVE PSHEADER-HRCNTA            TO WS-CNTA11.
           IF VIAL0001-DEBUG-SIM
              MOVE '2180-FORMATA-FICHEIRO' TO VIAL0015-CALLER-ID
              MOVE 'WS-MONTANT-PROCESS'    TO VIAL0015-CAMPO-NM (1)
              MOVE WS-MONTANT-PROCESS      TO VIAL0015-CAMPO-VLR(1)
              MOVE 'WS-TOTAL-COMISSOES'    TO VIAL0015-CAMPO-NM (2)
              MOVE WS-TOTAL-COMISSOES      TO VIAL0015-CAMPO-VLR(2)
              MOVE 'WS-TOTAL-IMPOSTOS '    TO VIAL0015-CAMPO-NM (3)
              MOVE WS-TOTAL-IMPOSTOS       TO VIAL0015-CAMPO-VLR(3)
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.
      *
           MOVE WS-CNTA                    TO PSCV7591-ORCONTA.
           MOVE PSHEADER-HRDPRO            TO PSCV7591-ORDPRC.
           MOVE PSHEADER-HRMOED            TO PSCV7591-ORMOED.
           MOVE WS-TOTAL-MONTANTE          TO PSCV7591-ORTOTS.
           MOVE WS-TOTAL-COMISSOES         TO PSCV7591-ORTCOM.
           MOVE WS-TOTAL-IMPOSTOS          TO PSCV7591-ORISEL.
           MOVE WS-TOTAL-DEBITOS           TO PSCV7591-ORVDEB.
           MOVE PSHEADER-HRREFORD          TO PSCV7591-ORDESC.
           MOVE PSHEADER-HRREFORD          TO PSCV7591-ORREFE.
           MOVE WS-REG-PROCESSADOS         TO PSCV7591-ORRPROC.
           MOVE WS-REG-N-PROCESS           TO PSCV7591-ORRNPRC.
           MOVE WS-TOTAL-REGISTOS          TO PSCV7591-ORRTPRC.
           MOVE WS-MONTANT-PROCESS         TO PSCV7591-ORVPROC.
           MOVE WS-MONTANT-N-PROCE         TO PSCV7591-ORVNPRC.
           MOVE WS-MONTANT-PROCESS         TO PSCV7591-ORVTPRC.
           MOVE PSHEADER-HRTOPE            TO PSCV7591-ORTSERV.
      *
           IF VIAL0001-DEBUG-SIM
              MOVE '2180-FORMATA-FICHEIRO  ' TO VIAL0015-CALLER-ID
              MOVE 'PSCV7591-ORTOTS        ' TO VIAL0015-CAMPO-NM(1)
              MOVE PSCV7591-ORTOTS           TO VIAL0015-CAMPO-VLR(1)
              MOVE 'PSCV7591-ORVPROC       ' TO VIAL0015-CAMPO-NM(2)
              MOVE PSCV7591-ORVPROC          TO VIAL0015-CAMPO-VLR(2)
              MOVE 'PSCV7591-ORVDEB        ' TO VIAL0015-CAMPO-NM(3)
              MOVE PSCV7591-ORVDEB           TO VIAL0015-CAMPO-VLR(3)
              MOVE 'PSCV7591-ORVTPRC       ' TO VIAL0015-CAMPO-NM(4)
              MOVE PSCV7591-ORVTPRC          TO VIAL0015-CAMPO-VLR(4)
              MOVE 'WS-TOTAL-COMISSOES     ' TO VIAL0015-CAMPO-NM(5)
              MOVE WS-TOTAL-COMISSOES        TO VIAL0015-CAMPO-VLR(5)
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
              MOVE  SPACES                 TO VIAL0015-CAMPOS-CHAVE
           END-IF.
      *
       2180-FORMATA-FICHEIRO-EXIT.
           EXIT.
      *--------------------------------------------------------------
      *        2190-DESCRITIVO-BALCAO
      *--------------------------------------------------------------
       2190-DESCRITIVO-BALCAO.
      *
           IF VIAL0001-DEBUG-SIM
              MOVE '2190-DESCRITIVO-BALCAO' TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.
      *
           INITIALIZE ETCL0002-COMMAREA  REPLACING  NUMERIC BY ZEROES
                                               ALPHANUMERIC BY SPACES.
           INITIALIZE ETCL9076-DATA      REPLACING  NUMERIC BY ZEROES
                                               ALPHANUMERIC BY SPACES.

           SET  ETCL9076-TTR-CPUBL          TO TRUE
      *
           MOVE PSHEADER-HRAGEN             TO ETCL9076-BALP
           MOVE 'S'                         TO ETCL9076-IPOS
           MOVE SPACES                      TO ETCL9076-SITBS
           MOVE SPACES                      TO ETCL9076-CICL
           MOVE ZEROES                      TO ETCL9076-ULTF
           MOVE 'N'                         TO ETCL9076-APRUT
           MOVE 999                         TO ETCL9076-NBALC

           PERFORM ETCP0002-FORM-ONLINE-IN
              THRU ETCP0002-FORM-ONLINE-IN-EXIT

           PERFORM CALL-ETR90076
              THRU CALL-ETR90076-EXIT.

           PERFORM ETCP0002-STD-END
              THRU ETCP0002-STD-END-EXIT

           IF ETCL0002-SEM-ERROS
              MOVE ETCL9076-RNOME(1)        TO WS-BALCAO
           ELSE
              MOVE SPACES                   TO WS-BALCAO
           END-IF.
      *
       2190-DESCRITIVO-BALCAO-EXIT.
           EXIT.
      *--------------------------------------------------------------
      *                     2020-OPEN
      *--------------------------------------------------------------
       2020-OPEN.
      *
           IF VIAL0001-DEBUG-SIM
              MOVE '2020-OPEN.'            TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.
      *
           MOVE PSCV7590-ORNCLI            TO PSDETALHE-DTNCLI .
           MOVE PSCV7590-ORDINT            TO PSDETALHE-DTDINT .
           IF PSCV7590-ORDINT EQUAL SPACES OR VIAK0002-DATA-MINIMA
              MOVE 0                       TO PSDETALHE-DTDINT
           ELSE
              MOVE PSCV7590-ORDINT         TO AQCW0005-DTX10
              PERFORM AQCP0005-CONV-DT10INDT8
                 THRU AQCP0005-CONV-DT10INDT8-EXIT
              MOVE AQCW0005-DT98           TO PSDETALHE-DTDINT
           END-IF.
           MOVE PSCV7590-ORNFIC            TO PSDETALHE-DTNFIC .
           MOVE PSCV7590-ORNREG            TO PSDETALHE-DTNREG .
           MOVE PSCK0002-REG-PROCESSADO    TO PSDETALHE-DTSITU .
      *
           SET  SW-CURSOR-NONE             TO TRUE.
      *
           IF SW-CURSOR-NONE
              SET SW-CURSOR-1              TO TRUE
           END-IF.
      *
           EVALUATE TRUE
              WHEN SW-CURSOR-1
                 EXEC SQL
                    OPEN CURPST01
                 END-EXEC
           END-EVALUATE.
      *
           MOVE CON-PSDETALH               TO VIAL0002-TABLE-NAME.
      *
           PERFORM 9020-DB2CHECK
              THRU 9029-DB2CHECK-EXIT.

       2029-OPEN-EXIT.
           EXIT.
      *--------------------------------------------------------------
      *                     2030-FETCH
      *--------------------------------------------------------------
       2030-FETCH.
      *
           EVALUATE TRUE
              WHEN SW-CURSOR-1
                 EXEC SQL
                    FETCH CURPST01
                       INTO :PSDETALHE-DTNCLI
                          , :PSDETALHE-DTDINT
                          , :PSDETALHE-DTNFIC
                          , :PSDETALHE-DTNREG
                          , :PSDETALHE-DTREF
                          , :PSDETALHE-DTTREG
                          , :PSDETALHE-DTTOPE
                          , :PSDETALHE-DTSITC
                          , :PSDETALHE-DTSITR
                          , :PSDETALHE-DTCBAN
                          , :PSDETALHE-DTCBAL
                          , :PSDETALHE-DTCNTA
                          , :PSDETALHE-DTCDIG
                          , :PSDETALHE-DTMONT
                          , :PSDETALHE-DTNOME
                          , :PSDETALHE-DTREFTR
                          , :PSDETALHE-DTDVAL
                          , :PSDETALHE-DTNTRY
                          , :PSDETALHE-DTNOCB
                          , :PSDETALHE-DTSITU
                          , :PSDETALHE-DTMAIL
                 END-EXEC
           END-EVALUATE.
      *
           MOVE CON-PSDETALH               TO VIAL0002-TABLE-NAME.
      *
           PERFORM 9020-DB2CHECK
              THRU 9029-DB2CHECK-EXIT.
      *
       2039-FETCH-EXIT.
           EXIT.
      *--------------------------------------------------------------
      *                       2040-CONTINUA
      *--------------------------------------------------------------
       2040-CONTINUA.
      *
           IF VIAL0001-DEBUG-SIM
              MOVE '2040-CONTINUA.' TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.
      *
           MOVE ZEROES                     TO PSCV7591-INDICE.
           PERFORM 2050-TRATA-OCCURS
              THRU 2059-TRATA-OCCURS-EXIT
             UNTIL DB2-NOTFND
                OR PSCV7591-PAGINA-CHEIA
                OR NOT VIAL0002-SEM-ERROS.
      *
           IF VIAL0002-SEM-ERROS
              IF NOT PSCV7591-PAGINA-CHEIA
                    COMPUTE PSCV7591-INDICE-INVERSO EQUAL
                         PSCV7591-INDICE-INVERSO - PSCV7591-INDICE
                    COMPUTE PSCV7591-DIMINUI-LENGTH EQUAL
                         PSCV7591-INDICE-INVERSO * PSCV7591-LENGTH-OCCUR
                    COMPUTE PSCV7591-LENGTH EQUAL PSCV7591-LENGTH -
                         PSCV7591-DIMINUI-LENGTH
                    SET  VIAL0002-FIM-CONSULTA TO TRUE
              END-IF
           END-IF.
      *
       2049-CONTINUA-EXIT.
           EXIT.
      *--------------------------------------------------------------
      *            2050-TRATA-OCCURS
      *--------------------------------------------------------------
       2050-TRATA-OCCURS.
      *
           IF VIAL0002-SEM-ERROS
              PERFORM 2520-VERIFICA-ERROS
                 THRU 2520-VERIFICA-ERROS-EXIT
           END-IF.
      *
           IF VIAL0002-SEM-ERROS
              PERFORM 2540-OBTEM-DESC-TEMPLATE
                 THRU 2540-OBTEM-DESC-TEMPLATE-EXIT
           END-IF.
      *
           IF VIAL0002-SEM-ERROS
           AND WS-ERR-DESC1 EQUAL SPACES
              PERFORM 2550-OBTEM-DESC-SITC
                 THRU 2550-OBTEM-DESC-SITC-EXIT
           END-IF.
      *
           IF VIAL0002-SEM-ERROS
              PERFORM 2560-FORMATA-LISTA
                 THRU 2560-FORMATA-LISTA-EXIT
           END-IF.

           PERFORM 2030-FETCH
              THRU 2039-FETCH-EXIT.
      *
       2059-TRATA-OCCURS-EXIT.
           EXIT.
      *--------------------------------------------------------------
      *                    2520-VERIFICA-ERROS
      *--------------------------------------------------------------
       2520-VERIFICA-ERROS.
      *
           IF VIAL0001-DEBUG-SIM
              MOVE '2520-VERIFICA-ERROS'   TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.
      *
           INITIALIZE RHMENSAG.
      *
           MOVE PSDETALHE-DTNCLI           TO PSHMENSAG-HMNCLI.
           MOVE PSDETALHE-DTDINT           TO PSHMENSAG-HMDINT.
           MOVE PSDETALHE-DTNFIC           TO PSHMENSAG-HMNFIC.
           MOVE PSDETALHE-DTNREG           TO PSHMENSAG-HMNREG.
      *
           EXEC SQL
              SELECT  HMTEMP
                INTO :PSHMENSAG-HMTEMP
                FROM  PSHMENSAG
               WHERE  HMNCLI = :PSHMENSAG-HMNCLI
                 AND  HMDINT = :PSHMENSAG-HMDINT
                 AND  HMNFIC = :PSHMENSAG-HMNFIC
                 AND  HMNREG = :PSHMENSAG-HMNREG
               ORDER  BY HTIMEEST DESC
               FETCH  FIRST ROW ONLY
           END-EXEC.

           MOVE CON-PSHMENSA               TO VIAL0002-TABLE-NAME.

           PERFORM 9020-DB2CHECK
              THRU 9029-DB2CHECK-EXIT.

PRA        IF DB2-NOTFND
PRA           PERFORM 2525-VERIFICA-ERROS
PRA              THRU 2525-VERIFICA-ERROS-EXIT
PRA        END-IF.
PRA
       2520-VERIFICA-ERROS-EXIT.
           EXIT.
PRA   *--------------------------------------------------------------
PRA   *                    2525-VERIFICA-ERROS
PRA   *--------------------------------------------------------------
PRA    2525-VERIFICA-ERROS.
PRA   *
PRA        IF VIAL0001-DEBUG-SIM
PRA           MOVE '2525-VERIFICA-ERROS'   TO VIAL0015-CALLER-ID
PRA           PERFORM VIAP0016-TRATA-DEBUG
PRA              THRU VIAP0016-TRATA-DEBUG-EXIT
PRA        END-IF.
PRA   *
PRA        INITIALIZE REG-PSMENSAG.
PRA   *
PRA        MOVE PSDETALHE-DTNCLI           TO PSMENSAG-MSNCLI.
PRA        MOVE PSDETALHE-DTDINT           TO PSMENSAG-MSDINT.
PRA        MOVE PSDETALHE-DTNFIC           TO PSMENSAG-MSNFIC.
PRA        MOVE PSDETALHE-DTNREG           TO PSMENSAG-MSNREG.
PRA   *
PRA        EXEC SQL
PRA           SELECT  MSTEMP
PRA             INTO :PSMENSAG-MSTEMP
PRA             FROM  PSMENSAG
PRA            WHERE  MSNCLI = :PSMENSAG-MSNCLI
PRA              AND  MSDINT = :PSMENSAG-MSDINT
PRA              AND  MSNFIC = :PSMENSAG-MSNFIC
PRA              AND  MSNREG = :PSMENSAG-MSNREG
PRA            ORDER  BY HTIMEEST DESC
PRA            FETCH  FIRST ROW ONLY
PRA        END-EXEC.
PRA
PRA        MOVE CON-PSMENSAG               TO VIAL0002-TABLE-NAME.
PRA
PRA        PERFORM 9020-DB2CHECK
PRA           THRU 9029-DB2CHECK-EXIT.
PRA
PRA        IF DB2-OK
PRA           MOVE PSMENSAG-MSTEMP         TO PSHMENSAG-HMTEMP
PRA        END-IF.
PRA
PRA    2525-VERIFICA-ERROS-EXIT.
PRA        EXIT.
      *--------------------------------------------------------------
      *                    2540-OBTEM-DESC-TEMPLATE
      *--------------------------------------------------------------
       2540-OBTEM-DESC-TEMPLATE.
      *
            IF VIAL0001-DEBUG-SIM
               MOVE '2540-OBTEM-DESC-TEMPL' TO VIAL0015-CALLER-ID
               PERFORM VIAP0016-TRATA-DEBUG
                  THRU VIAP0016-TRATA-DEBUG-EXIT
            END-IF.
      *
            MOVE 'PS608'                    TO ARCD0500-CTABELA.
            MOVE PSHMENSAG-HMTEMP           TO ARCD0500-CCOD.
            MOVE SPACES                     TO ARCD0500-C2COD
            MOVE 'PT-PT'                    TO ARCD0500-CLINGUA.
      *     MOVE SPACES                     TO ARCD0500-GDESC
      *
            EXEC SQL
              SELECT GDESC
                INTO :ARCD0500-GDESC
                FROM ARVT0500_CODESTABLE
               WHERE CTABELA = :ARCD0500-CTABELA
                 AND CCOD    = :ARCD0500-CCOD
                 AND C2COD   = :ARCD0500-C2COD
                 AND CLINGUA = :ARCD0500-CLINGUA
            END-EXEC.
		
		
           MOVE CON-CODESTBL               TO VIAL0002-TABLE-NAME.

           PERFORM 9020-DB2CHECK
              THRU 9029-DB2CHECK-EXIT.

           IF VIAL0002-SEM-ERROS
PRA   *       MOVE ARCD0500-GDESC          TO WS-ERR-DESC2
PRA           MOVE ARCD0500-GDESC          TO WS-ERR-DESC1
           END-IF.

       2540-OBTEM-DESC-TEMPLATE-EXIT.
           EXIT.
      *--------------------------------------------------------------
      *                    2550-OBTEM-DESC-SITC
      *--------------------------------------------------------------
       2550-OBTEM-DESC-SITC.
      *
            IF VIAL0001-DEBUG-SIM
               MOVE '2550-OBTEM-DESC-SITC'  TO VIAL0015-CALLER-ID
               PERFORM VIAP0016-TRATA-DEBUG
                  THRU VIAP0016-TRATA-DEBUG-EXIT
            END-IF.
      *
            MOVE 'PS605'                    TO ARCD0500-CTABELA.
            MOVE PSDETALHE-DTSITC           TO ARCD0500-CCOD.
            MOVE SPACES                     TO ARCD0500-C2COD.
            MOVE 'PT-PT'                    TO ARCD0500-CLINGUA.
      *     MOVE SPACES                     TO ARCD0500-GDESC
      *
            EXEC SQL
              SELECT GDESC
                INTO :ARCD0500-GDESC
                FROM ARVT0500_CODESTABLE
               WHERE CTABELA = :ARCD0500-CTABELA
                 AND CCOD    = :ARCD0500-CCOD
                 AND C2COD   = :ARCD0500-C2COD
                 AND CLINGUA = :ARCD0500-CLINGUA
            END-EXEC.
		
           MOVE CON-CODESTBL               TO VIAL0002-TABLE-NAME.

           PERFORM 9020-DB2CHECK
              THRU 9029-DB2CHECK-EXIT.

           IF VIAL0002-SEM-ERROS
              MOVE ARCD0500-GDESC          TO WS-ERR-DESC1
           END-IF.
            IF VIAL0001-DEBUG-SIM
               MOVE ARCD0500-GDESC          TO VIAL0015-CALLER-ID
               PERFORM VIAP0016-TRATA-DEBUG
                  THRU VIAP0016-TRATA-DEBUG-EXIT
            END-IF.

       2550-OBTEM-DESC-SITC-EXIT.
           EXIT.
      *--------------------------------------------------------------
      *                    2560-FORMATA-LISTA
      *--------------------------------------------------------------
       2560-FORMATA-LISTA.
      *
           IF VIAL0001-DEBUG-SIM
              MOVE '2560-FORMATA-LISTA'    TO VIAL0015-CALLER-ID
              MOVE WS-ERR                  TO VIAL0015-CAMPO-NM(1)
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.
      *
           ADD 1                           TO PSCV7591-INDICE.
      *
           MOVE PSDETALHE-DTNCLI
             TO PSCV7591-D-ORNCLI(PSCV7591-INDICE) .
           MOVE PSDETALHE-DTDINT           TO AQCW0005-DT98.

           PERFORM AQCP0005-CONV-DT8INDT10
              THRU AQCP0005-CONV-DT8INDT10-EXIT.

           MOVE AQCW0005-DTX10
             TO PSCV7591-D-ORDINT(PSCV7591-INDICE) .
           MOVE PSDETALHE-DTNFIC
             TO PSCV7591-D-ORNFIC(PSCV7591-INDICE) .
           MOVE PSDETALHE-DTNREG
             TO PSCV7591-D-ORNREG(PSCV7591-INDICE) .
           MOVE PSDETALHE-DTNOME
             TO PSCV7591-D-ORBNOM(PSCV7591-INDICE) .
      *
           MOVE PSDETALHE-DTCBAN           TO WS-CBAN.
           MOVE PSDETALHE-DTCBAL           TO WS-CBAL.
           MOVE PSDETALHE-DTCNTA           TO WS-CNTAN.
           MOVE PSDETALHE-DTCDIG           TO WS-CDIG.
           MOVE WS-NIB
             TO PSCV7591-D-ORBNIB(PSCV7591-INDICE) .
           MOVE PSDETALHE-DTMONT
             TO PSCV7591-D-ORBMNT(PSCV7591-INDICE) .
           MOVE WS-ERR
             TO PSCV7591-D-ORBERR1(PSCV7591-INDICE) .
      *
       2560-FORMATA-LISTA-EXIT.
           EXIT.
      *--------------------------------------------------------------
      *                     2070-CLOSE
      *--------------------------------------------------------------
       2070-CLOSE.
      *
           IF VIAL0001-DEBUG-SIM
              MOVE '2070-CLOSE.'           TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.

           EVALUATE TRUE
              WHEN SW-CURSOR-1
                 EXEC SQL
                    CLOSE CURPST01
                 END-EXEC
           END-EVALUATE.

       2079-CLOSE-EXIT.
           EXIT.
      *--------------------------------------------------------------
      *            3000-FINAL-PROGRAMA
      *--------------------------------------------------------------
       3000-FINAL-PROGRAMA.
      *
           IF VIAL0001-DEBUG-SIM
              MOVE 'PSI75900....-FINAL-PROGRAMA.'
                                              TO VIAL0015-CALLER-ID
              MOVE 'VIAL0002-IND-ERROS   ' TO VIAL0015-CAMPO-NM(1)
              MOVE VIAL0002-IND-ERROS      TO VIAL0015-CAMPO-VLR(1)
              MOVE 'VIAL0002-COD-ERRO-GRAVE' TO VIAL0015-CAMPO-NM(2)
              MOVE VIAL0002-COD-ERRO-GRAVE TO VIAL0015-CAMPO-VLR(2)
              MOVE 'PSCV7591-ORNCLI-MSG  ' TO VIAL0015-CAMPO-NM(3)
              MOVE PSCV7591-ORNCLI-MSG     TO VIAL0015-CAMPO-VLR(3)
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.

           MOVE PSCV7591-MSG               TO VIAL0001-MENSAGEM-OUTPUT.
           MOVE PSCV7591-LENGTH            TO VIAL0001-LENGTH-MSG.
           MOVE PSCV7591-NR-CAMPOS         TO VIAL0001-NR-CAMPOS.
           MOVE PSCV7591-INDICE            TO VIAL0001-OCORRENCIAS.

       3099-FINAL-PROGRAMA-EXIT.
           EXIT.

      ******************************************************************
       4000-TOTAL-REG-INTERNOS.
      ******************************************************************
           IF VIAL0001-DEBUG-SIM
              MOVE '4000-TOTAL-REG-INTERNOS' TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.
      *
           INITIALIZE RDETALHE.
           MOVE PSCV7590-ORNCLI                  TO PSDETALHE-DTNCLI.
           MOVE WS-DINT-98                       TO PSDETALHE-DTDINT.
           MOVE PSCV7590-ORNFIC                  TO PSDETALHE-DTNFIC.
           MOVE PSCK0002-REG-PROCESSADO          TO PSDETALHE-DTSITU.
           MOVE VIAL0001-CBANCO                  TO PSDETALHE-DTCBAN.
      *
           EXEC SQL
              SELECT  IFNULL(COUNT(DTMONT), 0)
                INTO :PSDETALHE-DTNREG
                FROM  PSDETALHE
               WHERE  DTNCLI  = :PSDETALHE-DTNCLI
                 AND  DTDINT  = :PSDETALHE-DTDINT
                 AND  DTNFIC  = :PSDETALHE-DTNFIC
                 AND  DTCBAN  = :PSDETALHE-DTCBAN
                 AND  DTNOCB <> 0
           END-EXEC.
      *
           MOVE CON-PSDETALH               TO VIAL0002-TABLE-NAME.

           PERFORM 9020-DB2CHECK
              THRU 9029-DB2CHECK-EXIT.
      *
           IF VIAL0002-SEM-ERROS
              MOVE PSDETALHE-DTNREG        TO WS-TOTAL-REG-INTERNOS
           ELSE
              MOVE PSCK0002-STATUS-ACTIVO  TO PSCV7591-ORNCLI-S
              MOVE PSCK0002-CAPLIC-PS      TO PSCV7591-ORNCLI-CAPLIC
              MOVE PSCK0001-ERR-HRNCLI     TO PSCV7591-ORNCLI-MSG
           END-IF.
      *
       4000-TOTAL-REG-INTERNOS-EXIT.
           EXIT.

      ******************************************************************
       4100-TOTAL-REG-OIC.
      ******************************************************************
           IF VIAL0001-DEBUG-SIM
              MOVE '4100-TOTAL-REG-OIC.    ' TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.
      *
           INITIALIZE RDETALHE.
           MOVE PSCV7590-ORNCLI                  TO PSDETALHE-DTNCLI.
           MOVE WS-DINT-98                       TO PSDETALHE-DTDINT.
           MOVE PSCV7590-ORNFIC                  TO PSDETALHE-DTNFIC.
           MOVE PSCK0002-REG-PROCESSADO          TO PSDETALHE-DTSITU.
           MOVE VIAL0001-CBANCO                  TO PSDETALHE-DTCBAN.
      *
           EXEC SQL
              SELECT  IFNULL(COUNT(DTMONT), 0)
                INTO :PSDETALHE-DTNREG
                FROM  PSDETALHE
               WHERE  DTNCLI  = :PSDETALHE-DTNCLI
                 AND  DTDINT  = :PSDETALHE-DTDINT
                 AND  DTNFIC  = :PSDETALHE-DTNFIC
                 AND  DTCBAN <> :PSDETALHE-DTCBAN
                 AND  DTNOCB <> 0
           END-EXEC.
      *
           MOVE CON-PSDETALH               TO VIAL0002-TABLE-NAME.

           PERFORM 9020-DB2CHECK
              THRU 9029-DB2CHECK-EXIT.
      *
           IF VIAL0002-SEM-ERROS
              MOVE PSDETALHE-DTNREG        TO WS-TOTAL-REG-OIC
           ELSE
              MOVE PSCK0002-STATUS-ACTIVO  TO PSCV7591-ORNCLI-S
              MOVE PSCK0002-CAPLIC-PS      TO PSCV7591-ORNCLI-CAPLIC
              MOVE PSCK0001-ERR-HRNCLI     TO PSCV7591-ORNCLI-MSG
           END-IF.
      *
       4100-TOTAL-REG-OIC-EXIT.
           EXIT.

      ******************************************************************
       5150-CORRIGE-COMISSOES.
      ******************************************************************
      *
           EVALUATE WS-SEQMV (WS-INDICE)
           WHEN PSCK0002-FICHEIRO-MIN THRU PSCK0002-FICHEIRO-MAX
                MOVE 1                   TO WS-QOPER (WS-INDICE)
           WHEN PSCK0002-TRFS-INT-MIN THRU PSCK0002-TRFS-INT-MAX
ES1203*         MOVE WS-REG-PROCESSADOS  TO WS-QOPER (WS-INDICE)
ES1203          MOVE WS-TOTAL-REG-INTERNOS TO WS-QOPER (WS-INDICE)
           WHEN PSCK0002-TRFS-OIC-MIN THRU PSCK0002-TRFS-OIC-MAX
                MOVE WS-TOTAL-REG-OIC    TO WS-QOPER (WS-INDICE)
           WHEN OTHER
                MOVE ZERO                TO WS-QOPER (WS-INDICE)
           END-EVALUATE.

      * Calculo do total de despesas efectas ao ficheiro
      * (exclu? movimenta??o contabil?stica das contrapartidas)
           IF WS-PACNT (WS-INDICE) NOT = CON-PACNT-MOV-CNT-CCB
              COMPUTE WS-TOTAL-COMISSOES = WS-TOTAL-COMISSOES +
                                         ( WS-VALOR (WS-INDICE) *
                                           WS-QOPER (WS-INDICE) )

      * Calculo do total dos impostos
              IF WS-COPER (WS-INDICE) EQUAL PSCK0002-IMP-SELO
                 COMPUTE WS-TOTAL-IMPOSTOS  = WS-TOTAL-IMPOSTOS  +
                                            ( WS-VALOR (WS-INDICE) *
                                              WS-QOPER (WS-INDICE) )
              END-IF
           END-IF.
      *
       5150-CORRIGE-COMISSOES-EXIT.
           EXIT.

      ******************************************************************
       5160-CORRIGE-COMISSOES.
      ******************************************************************
      *
           EVALUATE WS-SEQMV (WS-INDICE)
           WHEN PSCK0002-BORDREAUX-MIN THRU PSCK0002-BORDREAUX-MAX
      * SÓ COBRA A COMISSĂO SE O INDICADOR DE ISENÇĂO ESTIVER A "NĂO"
                IF PSCL5250-IIEBORDO-NAO
                  MOVE 1                   TO WS-QOPER (WS-INDICE)
                ELSE
                  MOVE 0                   TO WS-QOPER (WS-INDICE)
                END-IF
           WHEN OTHER
                MOVE ZERO                TO WS-QOPER (WS-INDICE)
           END-EVALUATE.

      * Calculo do total de despesas efectas ao ficheiro
      * (exclu? movimenta??o contabil?stica das contrapartidas)
           IF WS-PACNT (WS-INDICE) NOT = CON-PACNT-MOV-CNT-CCB
              COMPUTE WS-TOTAL-COMISSOES = WS-TOTAL-COMISSOES +
                                         ( WS-VALOR (WS-INDICE) *
                                           WS-QOPER (WS-INDICE) )
           END-IF.

       5160-CORRIGE-COMISSOES-EXIT.
           EXIT.

      ******************************************************************
       7000-REGISTA-EMISSAO.
      ******************************************************************
      *
           IF VIAL0001-DEBUG-SIM
              MOVE '7000-REGISTA-EMISSAO  ' TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.
      *
           PERFORM 7100-FORMATA-INPUT
              THRU 7100-FORMATA-INPUT-EXIT.
      *
           IF VIAL0002-SEM-ERROS
              PERFORM 7200-EXECUTA-CHAMADA
                 THRU 7200-EXECUTA-CHAMADA-EXIT
           END-IF.
      *
           IF VIAL0002-SEM-ERROS
              PERFORM 7300-FORMATA-OUTPUT
                 THRU 7300-FORMATA-OUTPUT-EXIT
           END-IF.
      *
       7000-REGISTA-EMISSAO-EXIT.
           EXIT.
      ******************************************************************
       7100-FORMATA-INPUT.
      ******************************************************************
      *
           IF VIAL0001-DEBUG-SIM
              MOVE '-----FORMATA-INPUT  ' TO VIAL0015-CALLER-ID
              MOVE 'PSCV7591-ORDINT     ' TO VIAL0015-CAMPO-NM(1)
              MOVE PSCV7591-ORDINT        TO VIAL0015-CAMPO-VLR(1)
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.
      *
           MOVE ZEROES                    TO PSCL5700-OCCURS
           PERFORM 7150-INFORMA-OCCURS
              THRU 7150-INFORMA-OCCURS-EXIT
             UNTIL PSCL5700-OCCURS = PSCV7591-INDICE
      *
           IF VIAL0001-DEBUG-SIM
              MOVE PSCL5700-OCCURS        TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.
      *    MOVE PSCV7591-ADE              TO PSCL5700-DADOS
           MOVE VIAL0001-CBANCO           TO PSCL5700-AT-CBAN
           MOVE VIAL0001-CBALM            TO PSCL5700-AT-BALM
           MOVE VIAL0001-DATA-EXTRN       TO PSCL5700-AT-DTOP
           MOVE VIAL0001-CMOEDA           TO PSCL5700-AT-CMOE
           MOVE VIAL0001-I-DEBUG          TO PSCL5700-AT-DEBUG
           MOVE PSCV7591-INDICE           TO PSCL5700-OCCURS
           MOVE PSCV7591-ORNCLI           TO PSCL5700-NCLI
           MOVE PSCV7591-ORNMCLI          TO PSCL5700-NMCLI
           MOVE PSCV7591-ORDINT           TO PSCL5700-DINT .
           MOVE PSCV7591-ORNFIC           TO PSCL5700-NFIC
           MOVE PSCV7591-ORNFICH          TO PSCL5700-NFICH
           MOVE PSCV7591-ORBIBLI          TO PSCL5700-BIBLI
           MOVE PSCV7591-ORNREG           TO PSCL5700-NREG
           MOVE PSCV7591-ORMOR1           TO PSCL5700-MOR1
           MOVE PSCV7591-ORPROV           TO PSCL5700-PROV
           MOVE PSCV7591-ORBALC           TO PSCL5700-BALC
           MOVE PSCV7591-ORCONTA          TO PSCL5700-CONTA
           MOVE PSCV7591-ORDPRC           TO PSCL5700-DPRC
           MOVE PSCV7591-ORMOED           TO PSCL5700-MOED
           MOVE PSCV7591-ORTOTS           TO PSCL5700-TOTS
           MOVE PSCV7591-ORTCOM           TO PSCL5700-TCOM
           MOVE PSCV7591-ORISEL           TO PSCL5700-ISEL
           MOVE PSCV7591-ORVDEB           TO PSCL5700-VDEB
           MOVE PSCV7591-ORDESC           TO PSCL5700-CDESC
           MOVE PSCV7591-ORREFE           TO PSCL5700-REFE
           MOVE PSCV7591-ORRPROC          TO PSCL5700-RPROC
           MOVE PSCV7591-ORRNPRC          TO PSCL5700-RNPRC
           MOVE PSCV7591-ORRTPRC          TO PSCL5700-RTPRC
           MOVE PSCV7591-ORVPROC          TO PSCL5700-VPROC
           MOVE PSCV7591-ORVNPRC          TO PSCL5700-VNPRC
           MOVE PSCV7591-ORVTPRC          TO PSCL5700-VTPRC
           MOVE PSCV7591-ORMOTIV          TO PSCL5700-MOTIV
      *
           PERFORM ETCP0002-FORM-ONLINE-IN
              THRU ETCP0002-FORM-ONLINE-IN-EXIT.
      *
       7100-FORMATA-INPUT-EXIT.
           EXIT.
      *--------------------------------------------------------------
      *            7150-INFORMA-OCCURS
      *--------------------------------------------------------------
       7150-INFORMA-OCCURS.
      *
           ADD  1                      TO PSCL5700-OCCURS
           MOVE PSCV7591-D-ORNCLI(PSCL5700-OCCURS)
             TO PSCL5700-D-NCLI(PSCL5700-OCCURS)
           MOVE PSCV7591-D-ORDINT(PSCL5700-OCCURS)
             TO PSCL5700-D-DINT(PSCL5700-OCCURS)
           MOVE PSCV7591-D-ORNFIC(PSCL5700-OCCURS)
             TO PSCL5700-D-NFIC(PSCL5700-OCCURS)
           MOVE PSCV7591-D-ORNREG(PSCL5700-OCCURS)
             TO PSCL5700-D-NREG(PSCL5700-OCCURS)
           MOVE PSCV7591-D-ORBNOM(PSCL5700-OCCURS)
             TO PSCL5700-D-BNOM(PSCL5700-OCCURS)
           MOVE PSCV7591-D-ORBNIB(PSCL5700-OCCURS)
             TO PSCL5700-D-BNIB(PSCL5700-OCCURS)
           MOVE PSCV7591-D-ORBMNT(PSCL5700-OCCURS)
             TO PSCL5700-D-BMNT(PSCL5700-OCCURS)
           MOVE PSCV7591-D-ORBERR1(PSCL5700-OCCURS)
             TO PSCL5700-D-BERR1(PSCL5700-OCCURS).
      *
       7150-INFORMA-OCCURS-EXIT.
           EXIT.

      ******************************************************************
       7200-EXECUTA-CHAMADA.
      ******************************************************************
      *
           IF VIAL0001-DEBUG-SIM
              MOVE '7200-EXECUTA-CHAMADA ' TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.
      *
           CALL PSCL5700-ROTINA         USING ETCL0002-COMMAREA
                                              PSCL5700-DATA.
      *
           IF VIAL0001-DEBUG-SIM
              MOVE '7200-EXECUTA-CHAMADA ' TO VIAL0015-CALLER-ID
              MOVE 'ETCL0002-ST-ERRO     ' TO VIAL0015-CAMPO-NM (1)
              MOVE  ETCL0002-ST-ERRO       TO VIAL0015-CAMPO-VLR(1)
              MOVE 'ETCL0002-RCODE       ' TO VIAL0015-CAMPO-NM (2)
              MOVE  ETCL0002-RCODE         TO VIAL0015-CAMPO-VLR(2)
              MOVE 'ETCL0002-IND-ERROS   ' TO VIAL0015-CAMPO-NM (3)
              MOVE  ETCL0002-IND-ERROS     TO VIAL0015-CAMPO-VLR(3)
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.
      *
           PERFORM ETCP0002-STD-END
              THRU ETCP0002-STD-END-EXIT

           IF VIAL0002-SEM-ERROS
              MOVE ETCL0002-RCODE          TO VIAW0020-RCODE

              PERFORM VIAP0020-TRATA-RCODE
                 THRU VIAP0020-TRATA-RCODE-EXIT
           END-IF.

           IF NOT ETCL0002-SEM-ERROS
              MOVE ETCL0002-IND-ERROS       TO VIAL0002-IND-ERROS
              SET  PSCV7591-ORNCLI-1          TO TRUE
              MOVE ETCL0002-ST-ERRO         TO PSCV7591-ORNCLI-MSG
              MOVE ETCL0002-CAPLIC-ERRO     TO PSCV7591-ORNCLI-CAPLIC
           END-IF.
      *
       7200-EXECUTA-CHAMADA-EXIT.
           EXIT.
      ******************************************************************
       7300-FORMATA-OUTPUT.
      ******************************************************************
      *
           IF VIAL0001-DEBUG-SIM
              MOVE '7300-FORMATA-OUTPUT ' TO VIAL0015-CALLER-ID
              MOVE 'VIAL0001-IND-ERROS  ' TO VIAL0015-CAMPO-NM(1)
              MOVE VIAL0001-IND-ERROS     TO VIAL0015-CAMPO-VLR(1)
              MOVE 'VIAL0002-IND-ERROS  ' TO VIAL0015-CAMPO-NM(2)
              MOVE VIAL0002-IND-ERROS     TO VIAL0015-CAMPO-VLR(2)
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.
      *
       7300-FORMATA-OUTPUT-EXIT.
           EXIT.

      ******************************************************************
       7400-VALIDA-DUPLICADO.
      ******************************************************************
      *
           IF VIAL0001-DEBUG-SIM
              MOVE '7400-VALIDA-DUPLICADO' TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.
      *
      * APENAS VAI VALIDAR O DUPLICADO NA PRIMEIRA VEZ QUE É CHAMADO
      * A PARTIR DO WEBSERVICE, O CAMPO MOEDA SÓ VEM A ESPAÇOS NA
      * PRIMEIRA EXECUÇĂO
      *
           IF PSCV7590-ORMOED EQUAL SPACES
              SET PSCL5700-TTR-VALIDA      TO TRUE
              PERFORM 7100-FORMATA-INPUT
                 THRU 7100-FORMATA-INPUT-EXIT
      *
              IF VIAL0002-SEM-ERROS
                 PERFORM 7200-EXECUTA-CHAMADA
                    THRU 7200-EXECUTA-CHAMADA-EXIT
              END-IF
      *
              IF VIAL0002-SEM-ERROS
                 PERFORM 7300-FORMATA-OUTPUT
                    THRU 7300-FORMATA-OUTPUT-EXIT
              END-IF
           END-IF.
      *
           IF VIAL0001-DEBUG-SIM
              MOVE 'ÇÇÇÇÇÇÇÇÇÇÇÇÇÇÇÇÇÇÇÇÇ' TO VIAL0015-CALLER-ID
              MOVE 'PSCL5700-DUPLICADO   ' TO VIAL0015-CAMPO-NM (1)
              MOVE  PSCL5700-DUPLICADO     TO VIAL0015-CAMPO-VLR(1)
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.

           IF VIAL0002-SEM-ERROS
              IF PSCL5700-DUPLICADO-SIM
                 PERFORM 7500-COBRA-COMISSAO
                    THRU 7500-COBRA-COMISSAO-EXIT
              END-IF
           END-IF.
      *
           IF VIAL0002-SEM-ERROS
              IF PSCL5700-DUPLICADO-SIM
                 PERFORM 7800-DESC-2VIA
                    THRU 7800-DESC-2VIA-EXIT
              END-IF
           END-IF.
      *
           IF VIAL0001-DEBUG-SIM
              MOVE '---------------------' TO VIAL0015-CALLER-ID
              MOVE 'PSCV7590-OR2VIA      ' TO VIAL0015-CAMPO-NM (1)
              MOVE  PSCV7590-OR2VIA        TO VIAL0015-CAMPO-VLR(1)
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.
      *
       7400-VALIDA-DUPLICADO-EXIT.
           EXIT.

      ******************************************************************
       7500-COBRA-COMISSAO.
      ******************************************************************
      *
           IF VIAL0001-DEBUG-SIM
              MOVE '7500-COBRA-COMISSAO  ' TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.
      *
           IF VIAL0002-SEM-ERROS
              PERFORM 7560-CONSULTA-CONTRATO
                 THRU 7560-CONSULTA-CONTRATO-EXIT
           END-IF.
      *
           IF VIAL0002-SEM-ERROS
              PERFORM 5100-CALCULA-COMISSOES
                 THRU 5100-CALCULA-COMISSOES-EXIT
           END-IF.

           IF VIAL0002-SEM-ERROS
              MOVE PSHEADER-HRNOCB           TO WS-HEADER-NOCB
              PERFORM 5500-COBRANCA-DESPESAS
                 THRU 5500-COBRANCA-DESPESAS-EXIT
           END-IF.
      *
           IF VIAL0002-SEM-ERROS
              IF PSHEADER-HRNOCB EQUAL ZEROES
              AND WS-HEADER-NOCB NOT EQUAL ZEROES
                 MOVE WS-HEADER-NOCB         TO PSHEADER-HRNOCB
                 PERFORM 7700-UPDATE-HEADER
                    THRU 7700-UPDATE-HEADER-EXIT
              END-IF
           END-IF.
      *
       7500-COBRA-COMISSAO-EXIT.
           EXIT.

      ******************************************************************
       7560-CONSULTA-CONTRATO.
      ******************************************************************

           IF VIAL0015-DEBUG-SIM
              MOVE '7560-CONSULTA-CONTRATO   ' TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.

           INITIALIZE PSCL5250-DATA.
           MOVE PSHEADER-HRTOPE            TO PSCL5250-TSERV
           MOVE PSHEADER-HRNCLI            TO PSCL5250-NCLI.
           MOVE ZEROES                     TO PSCL5250-NTRY
           MOVE SPACES                     TO PSCL5250-TMOV
           MOVE SPACES                     TO PSCL5250-DESC
           MOVE WS-PROGNAME                TO PSCL5250-PGMC.

           MOVE VIAL0001-CALLERID          TO PSCL5250-JOBNC.
           MOVE VIAL0001-CUSER-EXTRN       TO PSCL5250-USERC.
           MOVE VIAL0001-MSGQ              TO PSCL5250-PGMQC.
           MOVE PSCK0002-RCODE-OK          TO PSCL5250-RCODE.
           MOVE PSCK0002-ESTR-NEXE         TO PSCL5250-ESTR.
           MOVE PSCK0002-APTR-APL          TO PSCL5250-APTR.
           MOVE VIAL0001-CBANCO            TO PSCL5250-AT-CBAN
           MOVE VIAL0001-CBALM             TO PSCL5250-AT-BALM
           MOVE VIAL0001-DATA-EXTRN        TO PSCL5250-AT-DTOP
           MOVE VIAL0001-CMOEDA            TO PSCL5250-AT-CMOE
           MOVE VIAL0001-I-DEBUG           TO PSCL5250-AT-DEBUG

           CALL CON-PSM5250 USING ETCL0002-COMMAREA
                                  PSCL5250-DATA.

           MOVE PSCL5250-RCODE             TO VIAW0020-RCODE.

           PERFORM VIAP0020-TRATA-RCODE
              THRU VIAP0020-TRATA-RCODE-EXIT.

           IF NOT VIAL0002-SEM-ERROS
              MOVE VIAK0002-ERROS-FUNCAO     TO VIAL0002-IND-ERROS
              MOVE PSCK0001-SELECT-PSCONTRAT TO PSCV7591-ORNFIC-MSG
              MOVE PSCK0002-STATUS-ACTIVO    TO PSCV7591-ORNFIC-S
           END-IF.

           IF VIAL0015-DEBUG-SIM
              MOVE 'CALL PSM5250'          TO VIAL0015-CALLER-ID
              MOVE 'PSCL5250-RCODE'        TO VIAL0015-CAMPO-NM  (1)
              MOVE  PSCL5250-RCODE         TO VIAL0015-CAMPO-VLR (1)
              MOVE 'PSCL5250-CODERR'       TO VIAL0015-CAMPO-NM  (2)
              MOVE  PSCL5250-CODERR        TO VIAL0015-CAMPO-VLR (2)
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.


       7560-CONSULTA-CONTRATO-EXIT.
           EXIT.

      ******************************************************************
       7700-UPDATE-HEADER.
      ******************************************************************
      *
           IF VIAL0001-DEBUG-SIM
              MOVE '7700-UPDATE-HEADER   ' TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.
      *
           EXEC SQL
             UPDATE PSHEADER
                SET HRNOCB = :PSHEADER-HRNOCB
              WHERE HRNCLI = :PSHEADER-HRNCLI
                AND HRDINT = :PSHEADER-HRDINT
                AND HRNFIC = :PSHEADER-HRNFIC
           END-EXEC.

           MOVE CON-PSHEADER               TO VIAL0002-TABLE-NAME.

           PERFORM 9020-DB2CHECK
              THRU 9029-DB2CHECK-EXIT.
      *
       7700-UPDATE-HEADER-EXIT.
           EXIT.

      ******************************************************************
       7800-DESC-2VIA.
      ******************************************************************
      *
           IF VIAL0001-DEBUG-SIM
              MOVE '7800-DESC-2VIA       ' TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.
      *
           MOVE PSCK0002-TAB-2VIA          TO ARCL5005-CTABELA
           MOVE PSCK0002-CCOD-2VIA         TO ARCL5005-CCOD
           MOVE SPACES                     TO ARCL5005-C2COD
           MOVE PSCK0002-PT-PT             TO ARCL5005-CLINGUA
           MOVE SPACES                     TO ARCL5005-GDESC

           PERFORM CALL-ARM5005
              THRU CALL-ARM5005-EXIT.
      *
           IF NOT ETCL0002-SEM-ERROS
               MOVE VIAK0002-ERROS-FUNCAO    TO VIAL0002-IND-ERROS
               MOVE PSCK0002-STATUS-ACTIVO   TO PSCV7591-ORNFIC-S
               MOVE PSCK0001-HRNFIC-N-EXISTS TO PSCV7591-ORNFIC-MSG
               MOVE SPACES                   TO PSCV7591-OR2VIA
           ELSE
              MOVE ARCL5005-GDESC            TO PSCV7591-OR2VIA
           END-IF.
      *
       7800-DESC-2VIA-EXIT.
           EXIT.

      ******************************************************************
       5100-CALCULA-COMISSOES.
      ******************************************************************
           IF VIAL0001-DEBUG-SIM
              MOVE '5100-CALCULA-COMISSOES.' TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.

           INITIALIZE PSCL5035-DATA.
           MOVE WS-PROGNAME               TO PSCL5035-PGMC.
           MOVE PSCK0002-TTR-VAZIO         TO PSCL5035-TTR.
           MOVE VIAL0001-CALLERID          TO PSCL5035-JOBNC.
           MOVE VIAL0001-CUSER-EXTRN       TO PSCL5035-USERC.
           MOVE VIAL0001-MSGQ              TO PSCL5035-PGMQC.
           MOVE PSCK0002-ESTR-NEXE         TO PSCL5035-ESTR.
           MOVE PSCK0002-APTR-APL          TO PSCL5035-APTR.
           MOVE PSCV7590-ORNCLI            TO PSCL5035-NCLI.
           MOVE PSCV7590-ORDINT            TO AQCW0005-DTX10.
           PERFORM AQCP0005-CONV-DT10INDT8
              THRU AQCP0005-CONV-DT10INDT8-EXIT.
           MOVE AQCW0005-DT98              TO PSCL5035-DINT.
           MOVE PSCV7590-ORNFIC            TO PSCL5035-NFIC.
           MOVE PSHEADER-HRMOED            TO PSCL5035-MOED.
           MOVE PSHEADER-HRCANAL           TO PSCL5035-CANAL.
           MOVE ZEROES                     TO PSCL5035-RCODE.
           MOVE VIAL0001-CBANCO            TO PSCL5035-AT-CBAN
           MOVE VIAL0001-CBALM             TO PSCL5035-AT-BALM
           MOVE VIAL0001-DATA-EXTRN        TO PSCL5035-AT-DTOP
           MOVE VIAL0001-CMOEDA            TO PSCL5035-AT-CMOE
           MOVE VIAL0001-I-DEBUG           TO PSCL5035-AT-DEBUG
           MOVE PSHEADER-HRTOPE            TO PSCL5035-TSERV.

           IF VIAL0001-DEBUG-SIM
              MOVE '5100-CALCULA-COMISSOES.' TO VIAL0015-CALLER-ID
              MOVE 'PSCL5035-CANAL'          TO VIAL0015-CAMPO-NM(1)
              MOVE PSCL5035-CANAL            TO VIAL0015-CAMPO-VLR(1)
              MOVE 'PSCL5035-MOED '          TO VIAL0015-CAMPO-NM(2)
              MOVE PSCL5035-MOED             TO VIAL0015-CAMPO-VLR(2)
              MOVE 'PSCL5035-DINT '          TO VIAL0015-CAMPO-NM(3)
              MOVE PSCL5035-DINT             TO VIAL0015-CAMPO-VLR(3)
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.


      *    CALL PSCK0002-PSM5035
      *         USING PSCL5035-DATA.

           PERFORM PSCP5035-CALL-PSM5035
              THRU PSCP5035-CALL-PSM5035-EXIT.

           IF VIAL0001-DEBUG-SIM
              MOVE 'FIM EXECUÇĂO PSM5035   ' TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.

           MOVE PSCL5035-RCODE             TO VIAW0020-RCODE.

           PERFORM VIAP0020-TRATA-RCODE
              THRU VIAP0020-TRATA-RCODE-EXIT.

           IF VIAL0002-SEM-ERROS
              MOVE PSCL5035-SEQMV          TO WS-DIM-SEQMV
              MOVE PSCL5035-PACNT          TO WS-DIM-PACNT
              MOVE PSCL5035-COPER          TO WS-DIM-COPER
              MOVE PSCL5035-BALC           TO WS-DIM-BALC
              MOVE PSCL5035-CCB            TO WS-DIM-CCB
              MOVE PSCL5035-QOPER          TO WS-DIM-QOPER
              MOVE PSCL5035-VALOR          TO WS-DIM-VALOR
              MOVE PSCL5035-DESCR          TO WS-DIM-DESCR

              PERFORM 5160-CORRIGE-COMISSOES
                 THRU 5160-CORRIGE-COMISSOES-EXIT
              VARYING WS-INDICE FROM 1 BY 1
                UNTIL WS-INDICE > 100
           ELSE
              MOVE PSCK0002-STATUS-ACTIVO  TO PSCV7591-ORNCLI-S
              MOVE PSCK0001-ERR-CALL       TO PSCV7591-ORNCLI-MSG
           END-IF.

       5100-CALCULA-COMISSOES-EXIT.
           EXIT.

      ******************************************************************
       5500-COBRANCA-DESPESAS.
      ******************************************************************
           IF VIAL0001-DEBUG-SIM
              MOVE '5500-COBRANCA-DESPESAS.' TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.

           IF VIAL0002-SEM-ERROS
              PERFORM 5550-PROC-DESPESAS
                 THRU 5550-PROC-DESPESAS-EXIT
                      VARYING WS-INDICE FROM 1 BY 1
                        UNTIL WS-INDICE > 100
           END-IF.

           MOVE ZEROES                      TO WS-COD-OPER.
           MOVE SPACES                      TO WS-DESCRICAO.
           MOVE SPACES                      TO WS-CNTA-CCB.
      *
       5500-COBRANCA-DESPESAS-EXIT.
           EXIT.

      ******************************************************************
       5550-PROC-DESPESAS.
      ******************************************************************
           MOVE WS-COPER (WS-INDICE)        TO WS-COD-OPER.
           MOVE WS-DESCR (WS-INDICE)        TO WS-DESCRICAO.
           MOVE WS-CCB   (WS-INDICE)        TO WS-CNTA-CCB.
           MOVE CON-S                       TO WS-IDSP.

           COMPUTE WS-MONTANTE  = WS-VALOR (WS-INDICE) *
                                  WS-QOPER (WS-INDICE).

           IF WS-MONTANTE > ZEROES
              PERFORM 5400-DEBITO-ORDENANTE
                 THRU 5400-DEBITO-ORDENANTE-EXIT
           END-IF.

       5550-PROC-DESPESAS-EXIT.
           EXIT.

      ******************************************************************
       5400-DEBITO-ORDENANTE.
      ******************************************************************
           IF VIAL0001-DEBUG-SIM
              MOVE '5400-DEBITO-ORDENANTE' TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF

           INITIALIZE                          PSCL5070-DATA.
           MOVE WS-PROGNAME                 TO PSCL5070-PGMC.
           MOVE PSCK0002-TTR-DEBCB          TO PSCL5070-TTR
           MOVE ZEROES                      TO PSCL5070-AUTR

           MOVE VIAL0001-CALLERID           TO PSCL5070-JOBNC.
           MOVE VIAL0001-CUSER-EXTRN        TO PSCL5070-USERC.
           MOVE VIAL0001-CUSER-EXTRN        TO PSCL5070-USER .
           MOVE VIAL0001-MSGQ               TO PSCL5070-PGMQC.
           MOVE PSCK0002-ESTR-NEXE          TO PSCL5070-ESTR.
           MOVE PSCK0002-APTR-APL           TO PSCL5070-APTR.
           MOVE PSCK0002-HCLI-BMSG          TO PSCL5070-HCLI.
      *    MOVE PSHEADER-HRCNTA             TO WS-CNTA11.
           PERFORM 5410-OBTEM-CONTA
              THRU 5410-OBTEM-CONTA-EXIT
           MOVE WS-NCLI                     TO PSCL5070-NCLI.
           MOVE WS-CNTA                     TO PSCL5070-CONTA.
           MOVE WS-MONTANTE                 TO PSCL5070-MONT.
           MOVE WS-HEADER-NOCB              TO PSCL5070-NOPR.
           MOVE PSHEADER-HRMOED             TO PSCL5070-MOED.
           MOVE WS-NCLI                     TO PSCL5070-CCLI.
      ****************************************************************
           MOVE WS-IDSP                     TO PSCL5070-IDSP.
           MOVE WS-COD-OPER                 TO PSCL5070-COPE.
           MOVE WS-DESCRICAO                TO PSCL5070-DESC.
           MOVE WS-CNTA-CCB                 TO PSCL5070-CCB.
      ****************************************************************
           MOVE ZEROES                     TO PSCL5070-RCODE.
           MOVE VIAL0001-CBANCO            TO PSCL5070-AT-CBAN
           MOVE VIAL0001-CBALM             TO PSCL5070-AT-BALM
           MOVE VIAL0001-DATA-EXTRN        TO PSCL5070-AT-DTOP
           MOVE VIAL0001-CMOEDA            TO PSCL5070-AT-CMOE
           MOVE VIAL0001-I-DEBUG           TO PSCL5070-AT-DEBUG
           MOVE PSHEADER-HRAGEN            TO PSCL5070-BALM
           MOVE PSHEADER-HRTREMUN          TO PSCL5070-TREMUN
           MOVE PSHEADER-HRTOPE            TO PSCL5070-TOPE

           IF PSCL5070-MONT IS GREATER THAN ZEROES
      *       CALL PSCK0002-PSM5070
      *            USING PSCL5070-DATA
              PERFORM PSCP5070-CALL-PSM5070
                 THRU PSCP5070-CALL-PSM5070-EXIT

              MOVE PSCL5070-RCODE          TO VIAW0020-RCODE

              PERFORM VIAP0020-TRATA-RCODE
                 THRU VIAP0020-TRATA-RCODE-EXIT

              IF VIAL0002-SEM-ERROS
                 MOVE PSCL5070-NOPR        TO WS-HEADER-NOCB
              ELSE
                MOVE PSCK0002-STATUS-ACTIVO
                                           TO PSCV7591-ORNCLI-S
                MOVE PSCK0001-ERR-CALL     TO PSCV7591-ORNCLI-MSG
              END-IF
           END-IF.
      *
       5400-DEBITO-ORDENANTE-EXIT.
           EXIT.

      ******************************************************************
       5410-OBTEM-CONTA.
      ******************************************************************
      *
           INITIALIZE ETCL0188-DATA   REPLACING NUMERIC BY ZEROES
                                           ALPHANUMERIC BY SPACES
      *

           MOVE ZEROES                    TO ETCL0002-RCODE
           MOVE VIAL0001-VERSAO-SYS       TO ETCL0002-CVERSAO
ES5070     MOVE PSHEADER-HRCBAN           TO ETCL0188-CDNIB-BANCO
ES5070     MOVE PSHEADER-HRCBAL           TO ETCL0188-CDNIB-BALCAO
ES5070     MOVE PSHEADER-HRCNTA           TO ETCL0188-CDNIB-CONTA
ES5070     MOVE PSHEADER-HRCDIG           TO ETCL0188-CDNIB-CDIG

           SET  ETCL0188-CDTTR-CSCNT      TO TRUE

           CALL ETCL0188-ROTINA        USING ETCL0002-COMMAREA
                                             ETCL0188-DATA.
      *
      * Se o NIB năo existir no BANKA, segue o percurso normal
      * do programa e formata o erro de cliente inexistente mais
      * ŕ frente, formata os dados da conta com a conta de input
      *
           IF NOT ETCL0002-RCODE-OK
              SET ETCL0002-RCODE-OK        TO TRUE
              MOVE ETCL0188-CDNIB-NCLI     TO WS-NCLI
              MOVE ETCL0188-CDNIB-NATR     TO WS-NATR
              MOVE ETCL0188-CDNIB-SEQ      TO WS-NSEQ
      * Se estiver tudo bem, usa os dados da conta devolvidos
      * pela API
           ELSE
              MOVE ETCL0188-CDCONTA        TO WS-CNTA
           END-IF.
      *
       5410-OBTEM-CONTA-EXIT.
           EXIT.

      *--------------------------------------------------------------
           EXEC SQL INCLUDE VIAP0003 END-EXEC.
      *==============================================================
           COPY AQCP0005.
           COPY VIAP0016.
           COPY VIAP0020.
           COPY ETCP0002.
           COPY ARCR5005.
           COPY PSCP5035.
           COPY PSCP5070.
           COPY ETCP9076.
