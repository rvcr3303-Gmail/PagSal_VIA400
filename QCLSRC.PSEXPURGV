/*--------------------------------------------------------------*/
/*                                                              */
/*       Cadeia Batch de Expurgos (Pag. Salßrios) - Valid       */
/*                                                              */
/*--------------------------------------------------------------*/
           PGM
/*--------------------------------------------------------------*/
/* declarańŃo de variaveis */
           DCL VAR(&$RCODE)  TYPE(*DEC)  LEN(1 0) VALUE(0)
           DCL VAR(&CADEIA)  TYPE(*CHAR) LEN(10)  VALUE(PSEXPURG)
/*--------------------------------------------------------------*/
/* Programas                                                    */
/*--------------------------------------------------------------*/
           DLYJOB     DLY(000010)
           CALL BAB49999 PARM(&$RCODE &CADEIA)
/*--------------------------------------------------------------*/
FIM:       CALL ARB7900 PARM(&CADEIA)
           ENDPGM
