/*--------------------------------------------------------------*/
/*                                                              */
/*                 Expurgo da tabela PSFFICHREL                 */
/*                                                              */
/*--------------------------------------------------------------*/
   PGM PARM(&$RCODE)

/*--------------------------------------------------------------*/
/* Declara variáveis                                            */
/*--------------------------------------------------------------*/
   DCL VAR(&PGM)       TYPE(*CHAR)  LEN(10)   VALUE(PSB9035)
   DCL VAR(&FICH)      TYPE(*CHAR)  LEN(10)   VALUE(PSF9035)
   DCL VAR(&RCDLEN)    TYPE(*DEC)   LEN( 3)   VALUE(120)

   DCL VAR(&$RCODE)    TYPE(*DEC)   LEN(1 0)

   DCL VAR(&AMB)       TYPE(*CHAR)  LEN(01)
   DCL VAR(&LIB)       TYPE(*CHAR)  LEN(10)

/*--------------------------------------------------------------*/
/*  Obtém biblioteca de trabalho                                */
/*--------------------------------------------------------------*/
   CURLIB:   CALL   BAB49900 PARM(&$RCODE &AMB &LIB)
             IF     (&$RCODE>1) THEN(GOTO FINISH)

/*--------------------------------------------------------------*/
/* Recria o ficheiro de expurgados                              */
/*--------------------------------------------------------------*/
   PSF9035:
       DLTF    FILE(&LIB/&FICH)
       MONMSG  MSGID(CPF2105 CPF3220)
       CRTPF   FILE(&LIB/&FICH) RCDLEN(&RCDLEN) SIZE(*NOMAX)
       MONMSG  MSGID(CPF0000) EXEC(GOTO CMDLBL(ERRORF))

/*--------------------------------------------------------------*/
/* Invoca o programa de expurgo                                 */
/*--------------------------------------------------------------*/
   CALLPGM:
       CALL &LIB/&PGM PARM(&$RCODE)

/*--------------------------------------------------------------*/
       IF (&$RCODE *LE 1) THEN(GOTO CMDLBL(FINISH))
       ELSE (GOTO CMDLBL(ERRORP))

/*--------------------------------------------------------------*/
/* Erro de alocaçăo do ficheiro                                 */
/*--------------------------------------------------------------*/
   ERRORF:
       SNDUSRMSG ('Erro na alocaçăo do ficheiro ' *CAT &FICH)
       CHGVAR  VAR(&$RCODE)  VALUE(9)
       GOTO CMDLBL(FINISH)

/*--------------------------------------------------------------*/
/* Erro de execuçăo do programa                                 */
/*--------------------------------------------------------------*/
   ERRORP:
       SNDUSRMSG ('Erro na execuçăo do programa ' *CAT &PGM)
       CHGVAR  VAR(&$RCODE)  VALUE(9)
       GOTO CMDLBL(FINISH)

/*--------------------------------------------------------------*/
/* Termina execuçăo e devolve o controlo ao chamador            */
/*--------------------------------------------------------------*/
   FINISH:
       ENDPGM
