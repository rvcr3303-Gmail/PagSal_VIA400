/*--------------------------------------------------------------------*/
/*                                                                    */
/* Processamento Ficheiro Pagamentos em BATCH                         */
/*                                                                    */
/*--------------------------------------------------------------------*/
/*             L O G     D E     A L T E R A C O E S                  */
/*----------+------------+----------+---------------------------------*/
/*  INICIO  |   AUTOR    |   FIM    |      C O M E N T A R I O S      */
/*----------+------------+----------+---------------------------------*/
/* 20190912 | PLIMA      | 20190912 | Programa Inicial                */
/*----------+------------+----------+---------------------------------*/
       PGM PARM(&$RCODE)

/*--------------------------------------------------------------------*/
/* Declaracao de variaveis                                            */
/*--------------------------------------------------------------------*/
       DCL VAR(&$RCODE)  TYPE(*DEC)   LEN(1 0)

/*--------------------------------------------------------------------*/
/* Declaracao de variaveis                                            */
/*--------------------------------------------------------------------*/
   CALLPGM:
       IF ((&$RCODE=0) *OR (&$RCODE=1))   +
          CALL PGM(PSB4135) PARM(&$RCODE)

/*--------------------------------------------------------------------*/
/* Termina execucao e devolve o controlo ao chamador                  */
/*--------------------------------------------------------------------*/
   FINISH:
       ENDPGM
